---
import Base from '../layouts/Base.astro';
---
<style>
  section:not(.page-hero) {
    padding: calc(var(--space-lg) * 0.5) 0;
  }
  :global(.page-hero__subtitle) {
    max-width: 100%;
  }
  .bio-layout {
    display: grid;
    grid-template-columns: 210px 1fr;
    gap: var(--space-lg);
    align-items: stretch;
  }
  .bio-layout__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .bio-layout__photo-wrap {
    border-radius: 4px;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 3/4;
  }
  .bio-layout__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    display: block;
    transform: scale(1.3);
    transform-origin: center 25%;
  }
  @media (max-width: 900px) {
    .bio-layout {
      grid-template-columns: 1fr;
    }
    .bio-layout__photo-wrap {
      aspect-ratio: 4/3;
    }
  }
  @media (max-width: 768px) {
    .grid.grid--2 {
      grid-template-columns: 1fr;
    }
    .hide-mobile {
      display: none;
    }
  }
  .collab-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-md);
  }
  .collab-list li {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .collab-list li:last-child {
    border-bottom: none;
  }
  .collab-list strong {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
  }
  .collab-list .collab-role {
    color: var(--color-text-secondary);
  }
  .collab-highlights-row {
    display: flex;
    gap: var(--space-md);
    align-items: stretch;
  }
  .collab-highlights-row .collab-list {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    margin-bottom: 0;
  }
  .collab-highlights-row .collab-list li {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .collab-endorsement-stack {
    flex: 0 0 42%;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding-left: var(--space-md);
    border-left: 2px solid var(--color-border);
  }
  .collab-endorsement {
    margin: 0;
    padding: 0;
  }
  @media (max-width: 540px) {
    .collab-highlights-row {
      flex-direction: column;
    }
    .collab-endorsement-stack {
      flex: none;
      border-left: none;
      border-top: 2px solid var(--color-border);
      padding: var(--space-sm) 0 0;
    }
  }
  .collab-endorsement p {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }
  .collab-endorsement cite {
    font-size: 0.78rem;
    font-style: normal;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
  }
</style>
<Base title="Speaking & Advisory — Jane Muschenetz" description="Jane Muschenetz — MIT-trained analyst and award-winning poet — offers interdisciplinary keynotes, workshops, and programs on data, science communication, identity, and belonging. For universities, museums, think tanks, and cultural institutions.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero__title">Speaking<br>&amp; Advisory</h1>
      <p class="page-hero__subtitle">Programs and conversations that expand what's possible</p>
    </div>
  </section>

  <section class="reveal" style="padding-top:0;">
    <div class="container">
      <div class="bio-layout">
        <div>
          <div class="bio-layout__photo-wrap">
            <img src="/images/jane-book-fest.jpg" alt="Jane Muschenetz speaking" class="bio-layout__photo">
          </div>
        </div>
        <div class="bio-layout__text">
          <p style="font-size:1.05rem;line-height:1.7;">Jane Muschenetz brings an MIT-trained analyst's precision and a nationally recognized poet's acuity — with the lived experience of a refugee from Soviet Ukraine, to the same stage. Her talks and workshops bridge disciplinary and cultural divides with empathy, humor, and intellectual honesty.</p>
          <p style="font-size:1.05rem;line-height:1.7;margin-top:1em;">She invites lyrical resonance and connection between differing points of view into corporate, academic, and policy contexts and rigorous empirical thinking into literary and cultural spaces.</p>
          <p style="font-size:1.05rem;line-height:1.7;margin-top:1em;">Author of <em>POWER POINT</em> (2025 National Press Women Communications Prize) and <em>All the Bad Girls Wear Russian Accents</em> (San Diego Writers Festival 2024 Poetry Collection of the Year). Based in San Diego, with regular travel to Europe. Available for keynotes, panels, readings, workshops, and interdisciplinary programming — in person and virtually.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">Collaboration Highlights</h2>
      </div>
      <div class="collab-highlights-row">
        <ul class="collab-list">
          <li><strong>Mingei International Museum</strong> <span class="collab-role"> — Keynote, <em>Woman Powered</em></span></li>
          <li><strong>University of California, San Diego</strong> <span class="collab-role"> — Session host and performer, CODA Festival</span></li>
          <li><strong>Wende Museum</strong> <span class="collab-role"> — Featured performer, <em>Born in the USSR</em></span></li>
          <li><strong>The San Diego Union Tribune Festival of Books</strong> <span class="collab-role"> — Featured speaker, Poetry Stage</span></li>
          <li><strong>The San Diego Writers Festival</strong> <span class="collab-role"> — Program director, Poetry</span></li>
          <li><strong>Jewish Federation of San Diego</strong> <span class="collab-role"> — Lions of Judah Keynote, <em>Immigrant Impact</em></span></li>
        </ul>
        <div class="collab-endorsement-stack">
          <blockquote class="collab-endorsement">
            <p>"Jane's is a fresh and compelling voice for the power of art to unite us. She is an effective and admirable leader."</p>
            <cite>— Marni Freedman, Director, San Diego Writers Festival</cite>
          </blockquote>
          <blockquote class="collab-endorsement">
            <p>"I am consistently impressed by Jane's ability to build meaningful events and genuine connection with people from vastly different backgrounds and artistic disciplines."</p>
            <cite>— Jason Magabo Perez, San Diego Poet Laureate 2023–24</cite>
          </blockquote>
          <blockquote class="collab-endorsement">
            <p>"Our Lions of Judah audience — accomplished women with high expectations — left genuinely moved. Jane was as comfortable in conversation over lunch as she was at the podium, and the sense of community she sparked continued long after the event ended."</p>
            <cite>— Debbie Tirouda, Events Organizer, Jewish Federation of San Diego</cite>
          </blockquote>
        </div>
      </div>
      <div class="collab-logos" style="margin-top: var(--space-lg);">
        {[
          { n: 1,  ext: 'png', caption: 'Featured Speaker, Poetry Stage' },
          { n: 2,  ext: 'png', caption: 'Grant Recipient, Poetry to the People' },
          { n: 3,  ext: 'png', caption: 'Session Host & Performer, CODA Festival' },
          { n: 6,  ext: 'jpg', caption: 'Featured Performer, Born in the USSR' },
          { n: 7,  ext: 'png', caption: 'Keynote, Woman Powered' },
          { n: 14, ext: 'jpg', caption: 'Poetry Program Director' },
          { n: 5,  ext: 'png', caption: 'Regional Judge' },
          { n: 12, ext: 'png', caption: 'Exhibited Poet, Plaza de Panama' },
          { n: 4,  ext: 'png', caption: 'Recurring Visiting Author, MA Writing Program · Featured Performer, Poetry Day', hideOnMobile: true },
        ].map(({ n, ext, caption, hideOnMobile }) => (
          <figure class={`collab-logo-item${hideOnMobile ? ' hide-mobile' : ''}`}>
            <img src={`/images/collab-${String(n).padStart(2, '0')}.${ext}`} alt="Partner organization" />
            <figcaption>{caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">Sample Topics</h2>
      </div>
      <div class="grid grid--2" style="column-gap: var(--space-md); row-gap: var(--space-xs); margin-top: var(--space-md);">
        <div class="topic-group">
          <h4 class="topic-group__title">Humor &amp; Food</h4>
          <ul class="topic-group__list">
            <li>Recipe for a good life</li>
            <li>Poetry as comfort food</li>
            <li>Laughter and the "odds" of survival</li>
            <li>Food, culture, and memory</li>
            <li>The comedy of domestic life</li>
          </ul>
        </div>
        <div class="topic-group">
          <h4 class="topic-group__title">Art, Science, &amp; Society</h4>
          <ul class="topic-group__list">
            <li>The poet's laboratory</li>
            <li>Impactful scientific communication</li>
            <li>In good measure: data, poetics, and politics</li>
            <li>Intersection of art and science</li>
            <li>Love poems for nerds</li>
          </ul>
        </div>
        <div class="topic-group">
          <h4 class="topic-group__title">Place &amp; Belonging</h4>
          <ul class="topic-group__list">
            <li>Ukraine</li>
            <li>Identity, migration, and bridging divides</li>
            <li>Fostering creative ecosystems</li>
            <li>Public space as shared narrative</li>
            <li>Everything I learned in the Soviet diaspora</li>
          </ul>
        </div>
        <div class="topic-group">
          <h4 class="topic-group__title">Gender &amp; Faith</h4>
          <ul class="topic-group__list">
            <li>"Bad Girls" of Poetry</li>
            <li>Motherhood, women, and power</li>
            <li>Jewish storytelling</li>
            <li>Hope in difficult times</li>
            <li>Our common humanity</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="inquiries-section reveal" id="inquiries">
    <div class="container">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2 class="section-title">Inquiries</h2>
      </div>
      <div class="inquiries-grid">
        <div>
          <p>For invitations, collaborations, or advisory work, please share a short note with your timeline and context.</p>
        </div>
        <form class="contact-form" onsubmit="return false;">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message"></textarea>
          </div>
          <button type="submit" class="btn-submit">Send</button>
        </form>
      </div>
    </div>
  </section>
</Base>
