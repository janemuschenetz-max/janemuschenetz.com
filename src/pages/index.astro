---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const featuredItems = (await getCollection('featured')).filter((f) => f.data.active !== false);
---
<style>
  .press-img {
    transform: scale(1) !important;
    transition: transform 0.6s ease;
  }
  :global(.work-card:hover) .press-img,
  :global(.work-card__image:hover) .press-img {
    transform: scale(1.08) !important;
  }
  .hero__subhead {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1rem, 1.7vw, 1.3rem);
  }
  .hero__bio {
    font-size: clamp(0.875rem, 1.35vw, 1.08rem);
    line-height: 1.55;
    color: var(--color-text-secondary);
    max-width: 800px;
    margin-top: -0.75rem;
    margin-bottom: 3rem;
    opacity: 0.88;
    text-align: justify;
    hyphens: auto;
  }
  @media (min-width: 1200px) {
    .hero__subhead {
      white-space: nowrap;
    }
    .hero__bio {
      max-width: 770px;
      hyphens: none;
    }
    .hero__cta {
      margin-top: 0;
    }
  }
</style>
<script>
  document.querySelector('.hero__cta[href="#work"]')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.querySelector('#work')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
<Base title="Jane Yevgenia Muschenetz" description="Poet, data humanist, and translator between quantitative systems and human experience. MIT-trained analyst and award-winning author of POWER POINT. Interdisciplinary speaking, visual poetry, and public humanities programs." showDesktopNav={false}>
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__subtitle hero__subtitle--large" id="hero-words">Poetic practice at the intersection of economics, science, and belonging.</p>
        <p class="hero__subhead">Revealing the human connection behind data, through the lens of lyrical and visual art.</p>
        <p class="hero__bio">Author and artist Jane Muschenetz came to the US as a child refugee from Soviet Ukraine. Trained at MIT, she translates between quantitative systems and human experience — using data and visual forms to invite curiosity and connection. Her work spans poetry, public speaking, and art with a focus on legitimacy and the narratives that hold economic and human systems together.</p>
        <a href="#work" class="hero__cta">
          Explore My Work
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="reveal" id="work">
    <div class="container">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">Work</h2>
      </div>
      <div class="work-grid">
        <a href="/visual-data-poetry" class="work-card">
          <div class="work-card__image"><img src="/images/news.jpg" alt="Visual & Data Poetry" style="filter: saturate(40%);"></div>
          <div class="work-card__info">
            <h3 class="work-card__title">Visual &amp; Data Poetry</h3>
            <p style="margin-top:0.4rem; font-size:0.9rem;">Art, labor, gender, gun violence, and belonging.<br>Exhibits and installations.</p>
          </div>
        </a>
        <a href="/speaking-advisory" class="work-card">
          <div class="work-card__image"><img src="/images/jane-author-home.jpg" alt="Speaking & Advisory"></div>
          <div class="work-card__info">
            <h3 class="work-card__title">Speaking &amp; Advisory</h3>
            <p style="margin-top:0.4rem; font-size:0.9rem;">Keynotes and community conversations.<br>Institutional workshops.</p>
          </div>
        </a>
        <div class="work-card">
          <a href="https://www.technologyreview.com/2025/02/25/1111037/the-poetry-of-data/" target="_blank" rel="noopener" class="work-card__image" style="display:block;"><img src="/images/mit-card.jpg" alt="Writing & Press" class="press-img" style="object-fit:cover;object-position:center top;"></a>
          <div class="work-card__info">
            <h3 class="work-card__title"><a href="/writing-press" style="color:inherit;text-decoration:none;">Writing &amp; Press</a></h3>
            <p style="margin-top:0.4rem; font-size:0.9rem;">Publications and recognitions.<br>Author bio and media inquiries.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {featuredItems.map((item) => (
    <section class="reveal featured-section">
      <div class="container">
        <div class="section-header">
          <span class="section-number">02</span>
          <h2 class="section-title">Featured</h2>
        </div>
        <div class="featured-banner">
          <div class="featured-banner__image">
            <img src={item.data.image} alt={item.data.imageAlt} />
          </div>
          <div class="featured-banner__text">
            <h3>{item.data.title}</h3>
            <p class="lead">{item.data.subtitle}</p>
            <p>{item.data.description}</p>
            {item.data.link && (
              <a href={item.data.link} class="hero__cta mt-md" target="_blank" rel="noopener noreferrer">
                {item.data.linkText || 'Learn More'}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2 class="section-title">About</h2>
      </div>
      <div class="about-text">
        <p>Author and artist Jane Yevgenia Muschenetz came to the US as a child refugee from Soviet Ukraine. Trained at MIT and formerly with Bain &amp; Co, she translates between quantitative systems and human experience — using data, lyric, and visual form to reveal hidden narratives and invite curiosity and connection.</p>
        <p>Jane's work was recently featured in the <em>MIT Technology Review</em>, highlighting the intersection of statistical representation and art. Her second book, <strong>POWER POINT</strong>, earned the 2025 National Press Women Communications Prize in Creative Verse for its groundbreaking use of visual poetics, humor, and quantitative language to challenge structural inequality.</p>
        <p>In addition to writing and speaking, Jane leads workshops and conversations that bring humanistic and analytical lenses together — helping academic, civic, and professional communities think more clearly and feel more deeply about complex questions. She welcomes collaborations with institutions engaged in community building and cross-disciplinary inquiry.</p>
        <a href="/speaking-advisory" class="hero__cta mt-md">
          Learn More
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="inquiries-section reveal" id="inquiries">
    <div class="container">
      <div class="section-header">
        <span class="section-number">04</span>
        <h2 class="section-title">Inquiries</h2>
      </div>
      <div class="inquiries-grid">
        <div>
          <p>For invitations, collaborations, or advisory work, please share a short note with your timeline and context.</p>
        </div>
        <form class="contact-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="3b21ea97-ba4b-4c45-9b23-08285808b4d8">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message"></textarea>
          </div>
          <button type="submit" class="btn-submit">Send</button>
        </form>
      </div>
    </div>
  </section>
</Base>
