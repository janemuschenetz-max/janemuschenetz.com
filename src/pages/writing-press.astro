---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const pressItems = (await getCollection('press')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const books = (await getCollection('books')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<style>
  section:not(.page-hero) {
    padding: calc(var(--space-lg) * 0.5) 0;
  }
  section.section--tight-top {
    padding-top: var(--space-xs);
  }
</style>
<Base title="Writing & Press — Jane Muschenetz" description="Publications, recognitions, books, and biography of Jane Yevgenia Muschenetz.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero__title">Writing &amp; Press</h1>
      <p class="page-hero__subtitle">Curated highlights</p>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="pub-items-grid">
        <div class="section-header pub-col-header">
          <span class="section-number">01</span>
          <h2 class="section-title">Poems &amp; Essays</h2>
        </div>
        <div class="section-header pub-col-header">
          <span class="section-number">02</span>
          <h2 class="section-title">Press &amp; Recognitions</h2>
        </div>
        {publications.map((pub, i) => {
          const item = pressItems[i];
          const PubTag = pub.data.link ? 'a' : 'div';
          const isExternal = pub.data.link && !pub.data.link.startsWith('/');
          const pubAttrs = pub.data.link ? { href: pub.data.link, class: 'pub-item', ...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}) } : { class: 'pub-item' };
          const PressTag = item?.data.link ? 'a' : 'div';
          const pressAttrs = item?.data.link ? { href: item.data.link, class: 'pub-item', target: '_blank', rel: 'noopener noreferrer' } : { class: 'pub-item' };
          return (
            <>
              <PubTag {...pubAttrs}>
                <span class="pub-item__title">{pub.data.title}</span>
                <span class="pub-item__meta">{pub.data.publisher}</span>
                {pub.data.publisher === 'The Good Life Review, 2022' && <span class="pub-item__note">Honeybee Poetry Prize Winner · Pushcart Nominee</span>}
                {pub.data.publisher === 'Cathexis NW Press, 2024' && <span class="pub-item__note">First Place, 2025 NFPW Contest · Best of the Net Nominee</span>}
                {pub.data.publisher === 'Middle West Press, 2025' && <span class="pub-item__note">2025 War Poetry Postcard Prize Winner</span>}
              </PubTag>
              {item ? (
                <PressTag {...pressAttrs}>
                  <span class="pub-item__title">{item.data.title}</span>
                  <span class="pub-item__meta">{item.data.year}</span>
                </PressTag>
              ) : <div class="pub-item pub-item--empty" />}
            </>
          );
        })}
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2 class="section-title">Books</h2>
      </div>

      {books.map((book) => (
        <div class="book-feature">
          <div class="book-cover">
            <img src={book.data.cover} alt={book.data.coverAlt} />
          </div>
          <div class="book-info">
            <h3 style="display:flex;align-items:baseline;flex-wrap:wrap;gap:0.6rem;">
              <span>{book.data.title}</span>
              {book.data.title === 'POWER POINT' && (
                <span class="book-buy-links" style="font-size:0.85rem;font-weight:400;">
                  <span style="font-weight:500;color:var(--color-text);">Buy →</span>{' '}
                  <a href="https://www.amazon.com/Power-Point-Jane-Muschenetz/dp/1962405028/ref=sr_1_1?crid=GCKRJXP4AAPK&dib=eyJ2IjoiMSJ9.D5VuMTeV0OLUxn7L0cIHYrSnbrahVWtvaNEgwMsp5Go.8hBn07mxqiHgYFXJhV1L51QiirTsXjRmdG91xX8ZoT8&dib_tag=se&keywords=jane+muschenetz&qid=1773765718&sprefix=muschene%2Caps%2C262&sr=8-1" target="_blank" rel="noopener noreferrer">Amazon</a>{' · '}
                  <a href="https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/" target="_blank" rel="noopener noreferrer">Sheila-Na-Gig</a>
                </span>
              )}
              {book.data.title === 'All the Bad Girls Wear Russian Accents' && (
                <span class="book-buy-links" style="font-size:0.85rem;font-weight:400;">
                  <span style="font-weight:500;color:var(--color-text);">Buy →</span>{' '}
                  <a href="https://www.amazon.com/All-Girls-Wear-Russian-Accents/dp/1639802533/ref=sr_1_2?crid=GCKRJXP4AAPK&dib=eyJ2IjoiMSJ9.D5VuMTeV0OLUxn7L0cIHYrSnbrahVWtvaNEgwMsp5Go.8hBn07mxqiHgYFXJhV1L51QiirTsXjRmdG91xX8ZoT8&dib_tag=se&keywords=jane+muschenetz&qid=1773765718&sprefix=muschene%2Caps%2C262&sr=8-2" target="_blank" rel="noopener noreferrer">Amazon</a>{' · '}
                  <a href="https://kelsaybooks.com/products/all-the-bad-girls-wear-russian-accents?_pos=2&_sid=1df27cb79&_ss=r" target="_blank" rel="noopener noreferrer">Kelsay Books</a>
                </span>
              )}
            </h3>
            {book.data.quotes?.map((q, i) => (
              <div class={book.data.title === 'All the Bad Girls Wear Russian Accents' && i === 2 ? 'hide-mobile' : ''}>
                <blockquote class="book-quote">&ldquo;{q.text}&rdquo;</blockquote>
                <p class="book-quote-attribution">&mdash; {q.attribution}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="reveal section--tight-top">
    <div class="container">
      <div class="section-header">
        <span class="section-number">04</span>
        <h2 class="section-title">Projects</h2>
      </div>
      <div class="project-grid">
        <div class="project-card">
          <div class="project-card__images">
            <img src="/images/tiger-eyes.jpg" alt="Tiger Eyes painting by Jane Muschenetz for Palm Frond Zoo" class="project-card__img" style="object-position:50% 20%;" />
          </div>
          <div class="project-card__body">
            <h4><a href="https://www.palmfrondzoo.com/animalart" class="link-underline" target="_blank" rel="noopener noreferrer">Palm Frond Zoo</a></h4>
            <p>Folk and family art focused on sparking delight and creativity in unexpected places.</p>
            <a href="https://www.palmfrondzoo.com/animalart" class="link-underline" target="_blank" rel="noopener noreferrer" style="font-size:0.85rem;margin-top:auto;align-self:flex-end;">Learn more →</a>
          </div>
        </div>
        <div class="project-card">
          <div class="project-card__images">
            <img src="/images/table-m-2.jpg" alt="Chicken blintzes from Table M food blog" class="project-card__img" />
          </div>
          <div class="project-card__body">
            <h4><a href="https://muschenetz.com" class="link-underline" target="_blank" rel="noopener noreferrer">Table M</a></h4>
            <p>Food and travel blog featuring recipes and adventures of Ingo and Jane Muschenetz.</p>
            <a href="https://muschenetz.com" class="link-underline" target="_blank" rel="noopener noreferrer" style="font-size:0.85rem;margin-top:auto;align-self:flex-end;">Learn more →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">05</span>
        <h2 class="section-title">Biography</h2>
      </div>
      <div class="about-grid">
        <div class="about-image">
          <img src="/images/author-photo.jpg" alt="Jane Muschenetz author photo">
        </div>
        <div class="about-text">
          <p>Author and artist Jane Yevgenia Muschenetz fled Soviet Ukraine for the United States as a child. Her work spans poetry, public speaking, and visual art with a focus on legitimacy, civic ethics, and the narratives that hold economic and human systems together.</p>
          <p>Her words appear in <em>MIT Technology Review</em>, <em>KPBS Midday Edition</em>, <em>Spoken Word Paris</em>, and elsewhere. Recent honors include first place in the 2025 National Press Women Communications Prize and San Diego Writers Festival's 2024 Poetry Collection of the Year. Jane earned her MBA from MIT Sloan and her BA in Political Science from UC San Diego.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="inquiries-section reveal" id="inquiries">
    <div class="container">
      <div class="section-header">
        <span class="section-number">06</span>
        <h2 class="section-title">Inquiries</h2>
      </div>
      <div class="inquiries-grid">
        <div>
          <p>For media inquiries, interview requests, or permissions, please share a short note with your timeline and context.</p>
        </div>
        <form class="contact-form" onsubmit="return false;">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message"></textarea>
          </div>
          <button type="submit" class="btn-submit">Send</button>
        </form>
      </div>
    </div>
  </section>
</Base>
