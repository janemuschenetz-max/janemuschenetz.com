---
import Base from '../layouts/Base.astro';
---
<Base title="Writing & Press — Jane Muschenetz" description="Publications, recognitions, books, and biography of Jane Yevgenia Muschenetz.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero__title">Writing &amp; Press</h1>
      <p class="page-hero__subtitle">Curated highlights</p>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">Poems &amp; Essays</h2>
      </div>
      <div class="pub-list">
        <div class="pub-item">
          <span class="pub-item__title">All the Bad Girls Wear Russian Accents</span>
          <span class="pub-item__meta">Lucky Jefferson, 2022</span>
        </div>
        <a href="/poems/make-belief-600" class="pub-item link-underline">
          <span class="pub-item__title">You are 600% hotter than the Sun</span>
          <span class="pub-item__meta">Cathexis NW Press, 2024</span>
        </a>
        <div class="pub-item">
          <span class="pub-item__title">For Those of Us Forced to Flee</span>
          <span class="pub-item__meta">The Good Life Review, 2022</span>
        </div>
        <div class="pub-item">
          <span class="pub-item__title">Why do YOU love Taylor Swift?</span>
          <span class="pub-item__meta">Whale Road Review, 2025</span>
        </div>
        <div class="pub-item">
          <span class="pub-item__title">Venigret, a recipe for disaster</span>
          <span class="pub-item__meta">Punctured Lines, 2023</span>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">Press &amp; Recognitions</h2>
      </div>
      <div class="pub-list">
        <div class="pub-item">
          <span class="pub-item__title">MIT Technology Review &mdash; Data Poetry Feature</span>
          <span class="pub-item__meta">2025</span>
        </div>
        <div class="pub-item">
          <span class="pub-item__title">KPBS Midday Edition &mdash; On-air Interview</span>
          <span class="pub-item__meta">2023</span>
        </div>
        <div class="pub-item">
          <span class="pub-item__title">National Federation of Press Women &mdash; First Place (Verse)</span>
          <span class="pub-item__meta">2025</span>
        </div>
        <div class="pub-item">
          <span class="pub-item__title">San Diego Writers Festival &mdash; Poetry Collection of the Year</span>
          <span class="pub-item__meta">2024</span>
        </div>
        <div class="pub-item">
          <span class="pub-item__title">Middle West Press &mdash; First Place (War Poetry)</span>
          <span class="pub-item__meta">2025</span>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2 class="section-title">Books</h2>
      </div>

      <div class="book-feature">
        <div class="book-cover">
          <img src="/images/bad-girls-cover.png" alt="All the Bad Girls Wear Russian Accents book cover">
        </div>
        <div class="book-info">
          <h3>All the Bad Girls Wear Russian Accents</h3>
          <blockquote class="book-quote">"Crackling humor... delightful flavors of childhood, and tender celebration of our common humanity."</blockquote>
          <p class="book-quote-attribution">&mdash; Ari Honarvar, Nautilus Book Award Winner</p>
          <blockquote class="book-quote">"For anyone who has fought for the right to love, celebrate, and be themselves."</blockquote>
          <p class="book-quote-attribution">&mdash; Reader's Favorite, 5 Star Review</p>
        </div>
      </div>

      <div class="book-feature">
        <div class="book-cover">
          <img src="/images/power-point-cover.jpg" alt="POWER POINT book cover">
        </div>
        <div class="book-info">
          <h3>POWER POINT</h3>
          <blockquote class="book-quote">"Fascinating... strong and timely collection, worthy of first place in this category! Excellent work."</blockquote>
          <p class="book-quote-attribution">&mdash; National Federation of Press Women</p>
          <blockquote class="book-quote">"Astonishing... Muschenetz calls the U.S. to account for injustices against women and girls... while still offering us humor, beauty, and hope for the future."</blockquote>
          <p class="book-quote-attribution">&mdash; Katie Manning, Whale Road Review</p>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">04</span>
        <h2 class="section-title">Projects</h2>
      </div>
      <div class="project-item">
        <h4>Palm Frond Zoo</h4>
        <p>Folk and Family Art Initiative focused on sparking delight and creativity in unexpected ways and places.</p>
      </div>
      <div class="project-item">
        <h4>Table M</h4>
        <p>Food and Travel Blog of which Jane is the "butter half." Features recipes and stories reflecting the cultural heritage (Ukraine, Germany, America, etc.) and travels of Ingo and Jane Muschenetz.</p>
      </div>
    </div>
  </section>

  <section class="reveal">
    <div class="container">
      <div class="section-header">
        <span class="section-number">05</span>
        <h2 class="section-title">Biography</h2>
      </div>
      <div class="about-grid">
        <div class="about-image">
          <img src="/images/author-photo.jpg" alt="Jane Muschenetz author photo">
        </div>
        <div class="about-text">
          <p>Author and artist Jane Yevgenia Muschenetz fled Soviet Ukraine for the United States as a child. Her work spans poetry, public speaking, and visual art with a focus on legitimacy, civic ethics, and the narratives that hold economic and human systems together.</p>
          <p>Her work appears in <em>MIT Technology Review</em>, <em>KPBS Midday Edition</em>, <em>Spoken Word Paris</em>, and elsewhere. Recent honors include first place in the 2025 National Press Women Communications Prize and San Diego Writers Festival's 2024 Poetry Collection of the Year. Jane earned her MBA from MIT Sloan and her BA in Political Science from UC San Diego.</p>
        </div>
      </div>
    </div>
  </section>
</Base>
