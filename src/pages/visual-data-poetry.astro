---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const poems = await getCollection('poems');
---
<Base title="Visual & Data Poetry — Jane Muschenetz" description="Visual, science, and hybrid poetics. Exhibits and installations.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero__title">Visual &amp;<br>Data Poetry</h1>
      <p class="page-hero__subtitle">"How dazzling, this science!" &mdash; You are 600% Hotter than the Sun</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">Selected Samples</h2>
      </div>
      <div class="gallery-grid">
        {poems.map((poem) => (
          <a href={`/poems/${poem.data.slug}`} class="gallery-item reveal">
            <img src={poem.data.image || poem.data.illustration} alt={`${poem.data.title} — ${poem.data.description}`}>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
