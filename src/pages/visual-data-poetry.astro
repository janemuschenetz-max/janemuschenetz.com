<script is:inline>
// ── ME / TOO bar animation ────────────────────────────────────
(function () {
  ['#panel-me-gallery', '#panel-too-gallery'].forEach(function (sel) {
    var panel = document.querySelector(sel);
    if (!panel) return;
    var bars = Array.from(panel.querySelectorAll('rect')).filter(function (r) {
      var s = r.getAttribute('style') || '';
      return s.includes('fill:#e9bad7') || s.includes('fill:#b4c7e7');
    });
    if (!bars.length) return;
    var items = bars.map(function (rect) {
      var h = parseFloat(rect.getAttribute('height'));
      var y = parseFloat(rect.getAttribute('y'));
      return { el: rect, targetH: h, bottom: y + h };
    });
    items.forEach(function (item) {
      item.el.setAttribute('height', 0);
      item.el.setAttribute('y', item.bottom);
    });
    function animate() {
      var t0 = null;
      var dur = 2800;
      function step(ts) {
        if (!t0) t0 = ts;
        var elapsed = ts - t0;
        var done = true;
        items.forEach(function (item) {
          var p = Math.min(elapsed / dur, 1);
          if (p < 1) done = false;
          var e = 1 - Math.pow(1 - p, 3);
          item.el.setAttribute('height', item.targetH * e);
          item.el.setAttribute('y', item.bottom - item.targetH * e);
        });
        if (!done) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
    var svg = panel.querySelector('svg');
    if (!svg) return;
    var obs = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) { obs.disconnect(); animate(); }
    }, { threshold: 0.15 });
    obs.observe(svg);
  });
})();
</script>

