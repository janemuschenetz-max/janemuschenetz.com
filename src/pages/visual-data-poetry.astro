---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';

function loadSvg(file: string) {
  return readFileSync(join(process.cwd(), file), 'utf-8')
    .replace(/<\?xml[^?]*\?>/g, '')
    .replace(/<!DOCTYPE[^>]*>/g, '')
    .trim();
}
const momSmallSvg = loadSvg('public/images/mom_small.svg');
const safetyPointsSvg = loadSvg('public/images/safety_points_1.svg')
  .replace(/style="fill:#ff0;"/g, 'style="fill:#ff0;" class="sp-highlight"');
const meSmallSvg = loadSvg('public/images/me_small.svg');
const tooSmallSvg = loadSvg('public/images/too_small.svg');

const slugOrder = [
  '100-mom',
  'make-belief-600',
  'point-blank',
  'exclamation-point',
  'metoo',
  'when-always',
  'safety-points',
  'low-point',
];

const crossPairs: Record<string, string> = {
  'point-blank':      'gun-violence',
  'exclamation-point':'gun-violence',
  'safety-points':    'women-safety',
  'when-always':      'women-safety',
};

const heroPair = ['100-mom', 'make-belief-600'];

const liveVersions = new Set(['100-mom', 'make-belief-600', 'point-blank', 'exclamation-point', 'metoo', 'low-point']);
const poemHref = (slug: string) => liveVersions.has(slug) ? `/poems/${slug}-live` : `/poems/${slug}`;

const allPoems = (await getCollection('poems'))
  .filter((p) => slugOrder.includes(p.data.slug as string))
  .sort((a, b) => {
    const ai = slugOrder.indexOf(a.data.slug as string);
    const bi = slugOrder.indexOf(b.data.slug as string);
    return ai - bi;
  });

type Poem = typeof allPoems[0];
type GalleryItem =
  | { kind: 'single'; poem: Poem }
  | { kind: 'image-pair'; poem: Poem }
  | { kind: 'cross-pair'; first: Poem; second: Poem }
  | { kind: 'hero-row'; first: Poem; second: Poem };

const items: GalleryItem[] = [];
let i = 0;
while (i < allPoems.length) {
  const p = allPoems[i];
  const slug = p.data.slug as string;
  if (heroPair[0] === slug && i + 1 < allPoems.length && (allPoems[i + 1].data.slug as string) === heroPair[1]) {
    items.push({ kind: 'hero-row', first: p, second: allPoems[i + 1] });
    i += 2;
  } else if (p.data.type === 'image-pair' && p.data.image2) {
    items.push({ kind: 'image-pair', poem: p });
    i++;
  } else if (
    crossPairs[slug] &&
    i + 1 < allPoems.length &&
    crossPairs[allPoems[i + 1].data.slug as string] === crossPairs[slug]
  ) {
    items.push({ kind: 'cross-pair', first: p, second: allPoems[i + 1] });
    i += 2;
  } else {
    items.push({ kind: 'single', poem: p });
    i++;
  }
}
---
<style>
  .page-hero__subtitle { max-width: none; white-space: nowrap; }
  .page-hero { padding-bottom: 1.28rem; }
  .page-hero + section { padding-top: 1.28rem; }
  /* ── Background layers ───────────────────────────────────── */
  .gallery-banner,
  .gallery-banner-2 {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-size: 120%;
    background-position: center;
    background-repeat: no-repeat;
  }
  .gallery-banner {
    z-index: -2;
    background-image: url('/images/background_1.png');
    opacity: 0.18;
    filter: grayscale(30%);
    animation: bn-zoom 20s ease-in-out infinite;
  }
  .gallery-banner-2 {
    z-index: -1;
    background-image: url('/images/background_2.png');
    background-size: 110%;
    opacity: 0.12;
    filter: grayscale(20%);
    animation: bn-drift 28s ease-in-out infinite;
  }
  @keyframes bn-zoom {
    0%   { background-size: 120%; }
    50%  { background-size: 135%; }
    100% { background-size: 120%; }
  }
  @keyframes bn-drift {
    0%   { background-position: 40% 40%; background-size: 110%; }
    33%  { background-position: 60% 55%; background-size: 125%; }
    66%  { background-position: 45% 65%; background-size: 115%; }
    100% { background-position: 40% 40%; background-size: 110%; }
  }

  .gallery-pair {
    display: contents;
  }
  .gallery-single {
    display: contents;
  }

  /* ── Inline mom SVG ─────────────────────────────────────── */
  .mom-gallery-svg {
    position: absolute;
    inset: 0;
    transform: translateY(8%);
  }
  .mom-gallery-svg svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Safety Points inline SVG ───────────────────────────── */
  .sp-gallery-svg {
    position: absolute;
    inset: 0;
    opacity: 0.55;
  }
  .sp-gallery-svg svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  :global(.sp-highlight) {
    animation: sp-pulse 2.8s ease-in-out infinite;
  }
  :global(.sp-highlight:nth-child(2n))   { animation-delay: 0.4s; }
  :global(.sp-highlight:nth-child(3n))   { animation-delay: 0.9s; }
  :global(.sp-highlight:nth-child(4n))   { animation-delay: 1.5s; }
  :global(.sp-highlight:nth-child(5n))   { animation-delay: 2.1s; }
  @keyframes sp-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.05; }
  }

  /* ── SVG gallery tiles ───────────────────────────────────── */
  .gallery-svg-wrap {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    overflow: hidden;
    position: relative;
  }
  .svg-card-title {
    position: absolute;
    top: 1rem;
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: var(--color-text);
    opacity: 0.75;
    z-index: 2;
    pointer-events: none;
    user-select: none;
  }
  .svg-card-title--right {
    right: 1rem;
    text-align: right;
  }
  .svg-card-title--left {
    left: 1rem;
    text-align: left;
  }
  .gallery-svg-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    animation: gallery-chart-pulse 4s ease-in-out infinite;
  }
  .gallery-svg-wrap img.gallery-svg-sm {
    width: 85%;
    height: 85%;
  }
  .gallery-svg-wrap img.gallery-svg-sm-top,
  .gallery-svg-wrap div.gallery-svg-sm-top {
    width: 85%;
    height: 85%;
    animation: none;
  }
  .gallery-svg-wrap div.gallery-svg-sm-top svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Safety Points — zoom in so text fills the frame */
  .gallery-img-fill {
    transform: scale(1.35) translate(-7%, -12%);
    transform-origin: top left;
  }
  @keyframes gallery-chart-pulse {
    0%, 100% { filter: brightness(1) saturate(1); }
    50%       { filter: brightness(0.88) saturate(0.72); }
  }

  /* ── Live sun animation (make-belief-600 gallery card) ──── */
  .sun-title-circle {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 3;
    pointer-events: none;
  }
  .sun-gallery-live {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sun-gallery-rays {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 300%;
    height: 300%;
    transform: translate(-50%, -50%);
    animation: sun-gallery-spin 120s linear infinite;
  }
  @keyframes sun-gallery-spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }
  .sun-gallery-orb {
    position: relative;
    z-index: 1;
    width: 96%;
    height: auto;
    opacity: 0.4;
  }

  /* ── Low Point gallery — falling triangles ──────────────── */
  .lp-center {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin-top: 10%;
    text-align: center;
  }
  .lp-cash {
    width: clamp(216px, 66%, 504px);
    height: auto;
    margin-top: 0;
    opacity: 0.55;
  }
  .lp-gallery-live {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lp-rain {
    position: absolute;
    clip-path: polygon(50% 100%, 0% 0%, 100% 0%);
    background: #B5342A;
    animation: lp-fall linear infinite;
    animation-fill-mode: backwards;
  }
  @keyframes lp-fall {
    0%   { top: -40px; }
    100% { top: calc(100% + 10px); }
  }

  /* ── Override global hover scale for the ghost gun ────────── */
  :global(.gallery-item:hover .pb-ghost) {
    transform: translateY(30px);
  }

  /* ── Live bullet animation (point-blank gallery card) ────── */
  .pb-gallery-live {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pb-center {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-align: center;
  }
  .pb-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    letter-spacing: -0.01em;
    color: var(--color-text);
    user-select: none;
  }
  .pb-ghost {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 1;
    transform: translateY(30px);
    z-index: 0;
    pointer-events: none;
  }
  .pb-bullet {
    position: absolute;
    width: 44px;
    height: 16px;
    z-index: 1;
  }
  .pb-red  { background: #B5342A; }
  .pb-blue { background: #1F3A6E; }
  .pb-ltr {
    clip-path: polygon(0% 18%, 78% 18%, 100% 50%, 78% 82%, 0% 82%);
    animation: pb-fly-ltr linear infinite;
    animation-fill-mode: backwards;
  }
  .pb-rtl {
    clip-path: polygon(100% 18%, 22% 18%, 0% 50%, 22% 82%, 100% 82%);
    animation: pb-fly-rtl linear infinite;
    animation-fill-mode: backwards;
  }
  /* Pixel offsets guarantee the full bullet width is clipped before/after transit.
     Bullet crosses in the first ~10% of a long cycle, waits off-screen for the rest. */
  @keyframes pb-fly-ltr {
    0%   { left: -70px; }
    10%  { left: calc(100% + 20px); }
    100% { left: calc(100% + 20px); }
  }
  @keyframes pb-fly-rtl {
    0%   { left: calc(100% + 20px); }
    10%  { left: -70px; }
    100% { left: -70px; }
  }
</style>
<Base title="Visual & Data Poetry — Jane Muschenetz" description="Visual, science, and hybrid poetics. Exhibits and installations.">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero__title">Visual &amp;<br>Data Poetry</h1>
      <p class="page-hero__subtitle">"How dazzling, this science!" &mdash; You are 600% Hotter than the Sun</p>
    </div>
  </section>

  <div class="gallery-banner" aria-hidden="true"></div>
  <div class="gallery-banner-2" aria-hidden="true"></div>

  <section>
    <div class="container">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">Selected Samples</h2>
      </div>
      <div class="gallery-grid">
        {items.map((item) => {
          if (item.kind === 'image-pair') {
            const p = item.poem;
            const isMetoo = (p.data.slug as string) === 'metoo';
            return (
              <div class="gallery-pair">
                <a href={poemHref(p.data.slug as string)} class="gallery-item reveal">
                  {isMetoo ? (
                    <div class="gallery-svg-wrap">
                      <div id="panel-me-gallery" class="gallery-svg-sm-top" style="width:85%;height:85%;overflow:hidden;transform:translateY(12%);" aria-label={`${p.data.title} — ${p.data.description}`}><Fragment set:html={meSmallSvg} /></div>
                      <span style="position:absolute;top:22%;left:50%;transform:translate(-50%,-50%);white-space:nowrap;z-index:2;font-family:'Playfair Display',Georgia,serif;font-style:normal;font-weight:400;font-size:clamp(1.4rem,3.5vw,3rem);letter-spacing:-0.01em;color:var(--color-text);">#ME TOO</span>
                    </div>
                  ) : (
                    <img src={p.data.image as string} alt={`${p.data.title} — ${p.data.description}`}>
                  )}
                </a>
                <a href={poemHref(p.data.slug as string)} class="gallery-item reveal">
                  {isMetoo ? (
                    <div class="gallery-svg-wrap">
                      <div id="panel-too-gallery" class="gallery-svg-sm-top" style="width:85%;height:85%;overflow:hidden;transform:translateY(12%);" aria-label={`${p.data.title} (continued) — ${p.data.description}`}><Fragment set:html={tooSmallSvg} /></div>
                    </div>
                  ) : (
                    <img src={p.data.image2 as string} alt={`${p.data.title} (continued) — ${p.data.description}`}>
                  )}
                </a>
              </div>
            );
          }
          if (item.kind === 'hero-row') {
            const { first, second } = item;
            return (
              <div class="gallery-pair">
                <a href={poemHref(first.data.slug as string)} class="gallery-item reveal">
                  <div class="gallery-svg-wrap">
                    <div class="mom-gallery-svg" id="panel-mom-gallery" aria-label={`${first.data.title} — ${first.data.description}`}>
                      <Fragment set:html={momSmallSvg} />
                    </div>
                    <span class="pb-title" style="position:absolute;top:18%;left:50%;transform:translateX(-50%);white-space:nowrap;z-index:2;font-size:clamp(1.4rem,3.5vw,3rem);font-style:normal;">100%</span>
                  </div>
                </a>
                <a href={poemHref(second.data.slug as string)} class="gallery-item reveal" style="display:block;line-height:0;">
                  <div class="sun-gallery-live" aria-label={`${second.data.title} — ${second.data.description}`}>
                    <svg class="sun-title-circle" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <defs>
                        <path id="sun-arc" d="M 20,105 a 80,80 0 0,1 160,0"/>
                      </defs>
                      <text font-family="'Playfair Display', Georgia, serif" font-style="italic" font-size="11" fill="#5a4a3a" opacity="0.85" letter-spacing="1.5">
                        <textPath href="#sun-arc" startOffset="50%" text-anchor="middle">You Are 600% Hotter Than the Sun</textPath>
                      </text>
                    </svg>
                    <svg class="sun-gallery-rays" viewBox="-100 -100 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <g fill="#E8941A" opacity="0.18">
                        <polygon points="0,0 -3.5,-105 3.5,-105"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(30)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(60)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(90)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(120)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(150)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(180)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(210)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(240)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(270)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(300)"/>
                        <polygon points="0,0 -3.5,-105 3.5,-105" transform="rotate(330)"/>
                      </g>
                      <g fill="#E8941A" opacity="0.09">
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(15)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(45)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(75)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(105)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(135)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(165)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(195)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(225)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(255)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(285)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(315)"/>
                        <polygon points="0,0 -2,-105 2,-105" transform="rotate(345)"/>
                      </g>
                    </svg>
                    <img src="/images/sun_transparent.png" class="sun-gallery-orb" alt="" aria-hidden="true">
                  </div>
                </a>
              </div>
            );
          }
          if (item.kind === 'cross-pair') {
            const { first, second } = item;
            const firstIsPointBlank = (first.data.slug as string) === 'point-blank';
            const firstIsSafetyPoints = (first.data.slug as string) === 'safety-points';
            const secondIsExclamation = (second.data.slug as string) === 'exclamation-point';
            const secondIsSafetyPoints = (second.data.slug as string) === 'safety-points';
            return (
              <div class="gallery-pair">
                <a href={poemHref(second.data.slug as string)} class="gallery-item reveal" style={(secondIsExclamation || secondIsSafetyPoints) ? "display:block;line-height:0;" : ""}>
                  {secondIsExclamation ? (
                    <div class="pb-gallery-live" aria-label={`${second.data.title} — ${second.data.description}`}>
                      <img src="/images/poem-exclamation-point-blank.jpg" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" alt="" aria-hidden="true">
                      <div style="position:relative;z-index:2;text-align:center;font-family:'Playfair Display',Georgia,serif;font-style:italic;font-weight:400;font-size:clamp(1.4rem,3.5vw,3rem);letter-spacing:-0.01em;color:var(--color-text);line-height:1.15;">
                        Exclamation<br/>Point
                      </div>
                    </div>
                  ) : secondIsSafetyPoints ? (
                    <div class="pb-gallery-live" style="background:#fff;" aria-label={`${second.data.title} — ${second.data.description}`}>
                      <div class="sp-gallery-svg" aria-hidden="true"><Fragment set:html={safetyPointsSvg} /></div>
                      <div style="position:relative;z-index:2;text-align:center;font-family:'Playfair Display',Georgia,serif;font-style:italic;font-weight:400;font-size:clamp(1.4rem,3.5vw,3rem);letter-spacing:-0.01em;color:var(--color-text);line-height:1.15;">Safety<br/>Points</div>
                    </div>
                  ) : (
                    <img src={(second.data.image || second.data.illustration) as string} alt={`${second.data.title} — ${second.data.description}`}>
                  )}
                </a>
                <a href={poemHref(first.data.slug as string)} class="gallery-item reveal" style={(firstIsPointBlank || firstIsSafetyPoints) ? "display:block;line-height:0;" : ""}>
                  {firstIsPointBlank ? (
                    <div class="pb-gallery-live" aria-label={`${first.data.title} — ${first.data.description}`}>
                      <img src="/images/gun.svg" class="pb-ghost" alt="" aria-hidden="true">
                      <span class="pb-bullet pb-red  pb-ltr" style="top:12%; animation-duration:5.2s; animation-delay:0s;"></span>
                      <span class="pb-bullet pb-blue pb-rtl" style="top:31%; animation-duration:7.8s; animation-delay:1.1s; width:54px; height:19px;"></span>
                      <span class="pb-bullet pb-red  pb-rtl" style="top:52%; animation-duration:4.7s; animation-delay:3.5s;"></span>
                      <span class="pb-bullet pb-blue pb-ltr" style="top:68%; animation-duration:9.1s; animation-delay:0.6s;"></span>
                      <span class="pb-bullet pb-red  pb-ltr" style="top:80%; animation-duration:6.3s; animation-delay:2.3s; width:38px; height:13px;"></span>
                      <span class="pb-bullet pb-blue pb-rtl" style="top:42%; animation-duration:5.9s; animation-delay:5.8s;"></span>
                      <div class="pb-center">
                        <div style="text-align:center;font-family:'Playfair Display',Georgia,serif;font-style:italic;font-weight:400;font-size:clamp(1.4rem,3.5vw,3rem);letter-spacing:-0.01em;color:var(--color-text);line-height:1.15;">Point<br/>Blank</div>
                      </div>
                    </div>
                  ) : firstIsSafetyPoints ? (
                    <div class="pb-gallery-live" style="background:#fff;" aria-label={`${first.data.title} — ${first.data.description}`}>
                      <div class="sp-gallery-svg" aria-hidden="true"><Fragment set:html={safetyPointsSvg} /></div>
                      <div style="position:relative;z-index:2;text-align:center;font-family:'Playfair Display',Georgia,serif;font-style:italic;font-weight:400;font-size:clamp(1.4rem,3.5vw,3rem);letter-spacing:-0.01em;color:var(--color-text);line-height:1.15;">Safety<br/>Points</div>
                    </div>
                  ) : (
                    <img src={(first.data.image || first.data.illustration) as string} alt={`${first.data.title} — ${first.data.description}`}>
                  )}
                </a>
              </div>
            );
          }
          const p = item.poem;
          if ((p.data.slug as string) === 'low-point') {
            return (
              <div class="gallery-single">
                <a href="/poems/low-point-live" class="gallery-item reveal" aria-label="Low Point — US childhood poverty rate">
                  <div class="lp-gallery-live">
                    <span class="lp-rain" style="left:6%;  width:13px; height:21px; animation-duration:3.8s; animation-delay:0s;"></span>
                    <span class="lp-rain" style="left:18%; width:9px;  height:14px; animation-duration:5.3s; animation-delay:1.6s;"></span>
                    <span class="lp-rain" style="left:29%; width:17px; height:27px; animation-duration:4.2s; animation-delay:0.4s;"></span>
                    <span class="lp-rain" style="left:41%; width:11px; height:17px; animation-duration:6.7s; animation-delay:3.1s;"></span>
                    <span class="lp-rain" style="left:54%; width:20px; height:31px; animation-duration:3.4s; animation-delay:2.2s;"></span>
                    <span class="lp-rain" style="left:63%; width:10px; height:15px; animation-duration:5.9s; animation-delay:0.9s;"></span>
                    <span class="lp-rain" style="left:75%; width:15px; height:24px; animation-duration:4.6s; animation-delay:4.3s;"></span>
