---
import Base from '../../layouts/Base.astro';
---

<style>
  .live-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-lg);
  }
  .live-hero .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
  .live-hero .eyebrow a { color: inherit; text-decoration: none; }
  .live-hero .eyebrow a:hover { text-decoration: underline; }
  .live-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2px 8px;
    margin-left: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-secondary);
  }

  /* ── Slide text ─────────────────────────────────────────── */
  .slide {
    padding: var(--space-lg) 0 var(--space-md);
  }
  .slide-n {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
    font-family: var(--font-body);
  }
  .slide-text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.65;
    max-width: 640px;
  }

  /* ── Chart panels ────────────────────────────────────────── */
  .chart-panel {
    background: var(--color-bg-alt);
    border-radius: 4px;
    padding: var(--space-md) var(--space-md) var(--space-sm);
    margin-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .chart-panel.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .chart-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    margin-bottom: var(--space-sm);
  }
  #chart-mortality   { width: 100%; height: 340px; }
  #chart-preventable { width: 100%; height: 280px; }
  #chart-race        { width: 100%; height: 300px; }
  #chart-workforce   { width: 100%; height: 320px; }

  /* ── Explorer section ───────────────────────────────────── */
  .explorer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) 0;
  }
  .explorer h2 {
    margin-bottom: 0.25rem;
  }
  .explorer-intro {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    max-width: 560px;
  }
  .dataset-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .tab-btn {
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    padding: 6px 14px;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .tab-btn:hover,
  .tab-btn.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }
  .dataset-view { display: none; }
  .dataset-view.active { display: block; }
  .data-table-wrap {
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    font-family: var(--font-body);
  }
  .data-table th {
    text-align: left;
    font-weight: 500;
    border-bottom: 1px solid var(--color-text);
    padding: 6px 12px 6px 0;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }
  .data-table td {
    padding: 8px 12px 8px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .data-table tr:last-child td { border-bottom: none; }
  .bar-cell { width: 40%; }
  .bar-track {
    background: var(--color-bg-alt);
    border-radius: 2px;
    height: 10px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: #c4a8bc;
    border-radius: 2px;
    width: 0;
    transition: width 0.8s ease;
  }
  .source-note {
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
    line-height: 1.5;
  }

  /* ── About ──────────────────────────────────────────────── */
  .poem-about {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }

  @media (max-width: 600px) {
    #chart-mortality, #chart-race, #chart-workforce { height: 260px; }
    #chart-preventable { height: 240px; }
  }
</style>

<Base title="100% Mom (Live) — Jane Muschenetz" description="An animated, interactive data poem on maternal mortality and workforce inequality.">

  <!-- Hero -->
  <section class="live-hero">
    <div class="container">
      <p class="eyebrow"><a href="/visual-data-poetry">← Visual &amp; Data Poetry</a></p>
      <h1 class="page-hero__title">100% Mom <span class="live-badge">Interactive</span></h1>
      <p class="page-hero__subtitle" style="max-width:none;font-style:italic;">from <em>POWER POINT</em> (Sheila-Na-Gig Editions, 2024)</p>
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        <a href="/poems/100-mom" class="link-underline">View original static version →</a>
      </p>
    </div>
  </section>

  <section>
    <div class="container">

      <!-- Slide 1 -->
      <div class="slide">
        <p class="slide-n">1</p>
        <p class="slide-text">Moms are 5 times more likely to die giving birth in the US<br>than moms in other, 'equally developed' lands.</p>
      </div>

      <!-- Chart 1: Maternal Mortality -->
      <div class="chart-panel" id="panel-mortality">
        <p class="chart-label">Maternal Mortality Ratio — Deaths per 100,000 Live Births, 2020</p>
        <div id="chart-mortality"></div>
      </div>

      <!-- Slide 2 -->
      <div class="slide">
        <p class="slide-n">2</p>
        <p class="slide-text">Some of these moms we can't save, but most, we can.</p>
      </div>

      <!-- Chart 2: Preventable -->
      <div class="chart-panel" id="panel-preventable">
        <p class="chart-label">US Pregnancy-Related Deaths — Preventability, 2020</p>
        <div id="chart-preventable"></div>
      </div>

      <!-- Slide 3 -->
      <div class="slide">
        <p class="slide-n">3</p>
        <p class="slide-text">Black and Hispanic moms die more frequently than do White.<br>We study this, make charts / policies, and write</p>
      </div>

      <!-- Chart 3: Race -->
      <div class="chart-panel" id="panel-race">
        <p class="chart-label">US Maternal Mortality Rate by Race/Ethnicity — Per 100,000 Live Births, 2020</p>
        <div id="chart-race"></div>
      </div>

      <!-- Slide 4 -->
      <div class="slide">
        <p class="slide-n">4</p>
        <p class="slide-text">about labor (paid and unpaid), status, values of the hour…</p>
      </div>

      <!-- Chart 4: Workforce -->
      <div class="chart-panel" id="panel-workforce">
        <p class="chart-label">Global Workforce by Gender — 2020</p>
        <div id="chart-workforce"></div>
      </div>

      <!-- Slide 5 -->
      <div class="slide">
        <p class="slide-n">5</p>
        <p class="slide-text">What is the "real cost" of good?<br>Is knowledge power?</p>
      </div>

    </div>
  </section>

  <!-- Explorer -->
  <section class="explorer">
    <div class="container">
      <h2>Explore the Data</h2>
      <p class="explorer-intro">The underlying datasets behind the poem. Sort, compare, and explore the numbers directly.</p>

      <div class="dataset-tabs">
        <button class="tab-btn active" data-tab="mortality">Maternal Mortality</button>
        <button class="tab-btn" data-tab="preventable">Preventability</button>
        <button class="tab-btn" data-tab="race">Race &amp; Ethnicity</button>
        <button class="tab-btn" data-tab="workforce">Workforce</button>
      </div>

      <!-- Mortality dataset -->
      <div class="dataset-view active" id="tab-mortality">
        <div class="data-table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Country</th>
                <th>Deaths per 100,000 live births</th>
                <th class="bar-cell">Relative rate</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Norway</td><td>2</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:8.3%"></div></div></td></tr>
              <tr><td>Netherlands</td><td>3</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:12.5%"></div></div></td></tr>
              <tr><td>Germany</td><td>4</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:16.7%"></div></div></td></tr>
              <tr><td>Canada</td><td>8</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:33.3%"></div></div></td></tr>
              <tr><td>France</td><td>8</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:33.3%"></div></div></td></tr>
              <tr><td>United Kingdom</td><td>10</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:41.7%"></div></div></td></tr>
              <tr><td><strong>United States</strong></td><td><strong>24</strong></td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:100%;background:#9b7aaa;"></div></div></td></tr>
            </tbody>
          </table>
        </div>
        <p class="source-note">Source: Commonwealth Fund, "The U.S. Maternal Mortality Crisis Continues to Worsen: An International Comparison," 2022.</p>
      </div>

      <!-- Preventable dataset -->
      <div class="dataset-view" id="tab-preventable">
        <div class="data-table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>Category</th><th>Percentage</th><th class="bar-cell"></th></tr>
            </thead>
            <tbody>
              <tr><td>Preventable</td><td>84%</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:84%;background:#9b7aaa;"></div></div></td></tr>
              <tr><td>Not preventable</td><td>16%</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:16%"></div></div></td></tr>
            </tbody>
          </table>
        </div>
        <p class="source-note">Source: "Most pregnancy-related deaths are preventable," Hear Her Campaign, CDC, 2022.</p>
      </div>

      <!-- Race dataset -->
      <div class="dataset-view" id="tab-race">
        <div class="data-table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>Race / Ethnicity</th><th>Deaths per 100,000 live births</th><th class="bar-cell">Relative rate</th></tr>
            </thead>
            <tbody>
              <tr><td>Hispanic</td><td>18.2</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:33%"></div></div></td></tr>
              <tr><td>White</td><td>19.1</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:34.7%"></div></div></td></tr>
              <tr><td><strong>Black</strong></td><td><strong>55.3</strong></td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:100%;background:#9b7aaa;"></div></div></td></tr>
            </tbody>
          </table>
        </div>
        <p class="source-note">Source: CDC, NCHS, "Life Stages and Populations by Sex," 2020 data.</p>
      </div>

      <!-- Workforce dataset -->
      <div class="dataset-view" id="tab-workforce">
        <div class="data-table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>Category</th><th>% Women</th><th>% Men</th><th class="bar-cell">Women's share</th></tr>
            </thead>
            <tbody>
              <tr><td>Unpaid Labor Hours</td><td>75%</td><td>25%</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:75%;background:#9b7aaa;"></div></div></td></tr>
              <tr><td>Low-wage Workers</td><td>60%</td><td>40%</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:60%;background:#c4a8bc;"></div></div></td></tr>
              <tr><td>Senior Management</td><td>28%</td><td>72%</td><td class="bar-cell"><div class="bar-track"><div class="bar-fill" style="--pct:28%"></div></div></td></tr>
            </tbody>
          </table>
        </div>
        <p class="source-note">Source: ILO, "Women Work More, But are Still Paid Less," 2022; UN, "The World's Women 2020 Trends and Statistics."</p>
      </div>

    </div>
  </section>

  <!-- About -->
  <section class="poem-about">
    <div class="container--narrow">
      <h3>About This Poem</h3>
      <p>'100% Mom' renders maternal mortality, unpaid labor, and workforce inequality through charts created in Microsoft PowerPoint. The data reveals that US moms are 5 times more likely to die giving birth than mothers in other developed nations, while women bear 60–75% of unpaid labor. This interactive version animates those charts in the browser.</p>
      <h4 class="mt-md">Data Sources</h4>
      <div class="poem-footnotes">
        <ol>
          <li>"Life Stages and Populations by Sex," CDC, NCHS; "Most pregnancy-related deaths are preventable," Hear Her Campaign, CDC, 2022; "The U.S. Maternal Mortality Crisis Continues to Worsen: An International Comparison," Commonwealth Fund, 2022; "The World's Women 2020 Trends and Statistics," United Nations; "Women Work More, But are Still Paid Less," Intl. Labor Organization Report, 2022.</li>
        </ol>
      </div>
    </div>
  </section>

<!-- ── AMCharts 5 ─────────────────────────────────────────────────────── -->
<script is:inline src="https://cdn.amcharts.com/lib/5/index.js"></script>
<script is:inline src="https://cdn.amcharts.com/lib/5/xy.js"></script>
<script is:inline src="https://cdn.amcharts.com/lib/5/percent.js"></script>
<script is:inline src="https://cdn.amcharts.com/lib/5/themes/Animated.js"></script>
<script is:inline>

const MAUVE      = am5.color(0xc4a8bc);
const MAUVE_DARK = am5.color(0x9b7aaa);
const MAUVE_LITE = am5.color(0xe0d0dc);
const NEUTRAL    = am5.color(0xb8b8b8);
const BG         = am5.color(0xF0EFEB);

// ── Intersection Observer: init charts on scroll ──────────────────────
const panels = {
  "panel-mortality":   initMortality,
  "panel-preventable": initPreventable,
  "panel-race":        initRace,
  "panel-workforce":   initWorkforce,
};
const initialized = new Set();

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const id = entry.target.id;
      entry.target.classList.add("visible");
      if (!initialized.has(id) && panels[id]) {
        initialized.add(id);
        panels[id]();
      }
    }
  });
}, { threshold: 0.15 });

Object.keys(panels).forEach(id => {
  const el = document.getElementById(id);
  if (el) observer.observe(el);
});

// ── Chart 1: Maternal Mortality by Country ────────────────────────────
function initMortality() {
  const root = am5.Root.new("chart-mortality");
  root.setThemes([am5themes_Animated.new(root)]);

  const chart = root.container.children.push(am5xy.XYChart.new(root, {
    panX: false, panY: false,
    wheelX: "none", wheelY: "none",
    paddingLeft: 0, paddingRight: 10,
  }));

  chart.get("colors").set("colors", [MAUVE_LITE, MAUVE_LITE, MAUVE_LITE, MAUVE_LITE, MAUVE_LITE, MAUVE_LITE, MAUVE_DARK]);

  const xRenderer = am5xy.AxisRendererX.new(root, { minGridDistance: 30 });
  xRenderer.labels.template.setAll({ fontSize: 12, fill: am5.color(0x666666) });
  xRenderer.grid.template.setAll({ stroke: am5.color(0xdddddd), strokeWidth: 1 });

  const xAxis = chart.xAxes.push(am5xy.CategoryAxis.new(root, {
    categoryField: "country",
    renderer: xRenderer,
  }));

  const yRenderer = am5xy.AxisRendererY.new(root, {});
  yRenderer.labels.template.setAll({ fontSize: 12, fill: am5.color(0x666666) });
  yRenderer.grid.template.setAll({ stroke: am5.color(0xdddddd), strokeWidth: 1, strokeDasharray: [3,3] });

  const yAxis = chart.yAxes.push(am5xy.ValueAxis.new(root, {
    min: 0,
    strictMinMax: true,
    renderer: yRenderer,
  }));

  yAxis.children.unshift(am5.Label.new(root, {
    rotation: -90, y: am5.p50, centerX: am5.p50,
    text: "Deaths per 100,000 live births",
    fontSize: 11, fill: am5.color(0x999999),
  }));

  const series = chart.series.push(am5xy.ColumnSeries.new(root, {
    xAxis, yAxis,
    valueYField: "value",
    categoryXField: "country",
    tooltip: am5.Tooltip.new(root, {
      labelText: "{categoryX}: {valueY} per 100k",
    }),
  }));

  series.columns.template.setAll({
    cornerRadiusTL: 3, cornerRadiusTR: 3,
    strokeOpacity: 0,
    width: am5.percent(70),
  });
  series.columns.template.adapters.add("fill", function(fill, target) {
    return target.dataItem.dataContext.color;
  });

  series.bullets.push(() => am5.Bullet.new(root, {
    locationY: 1,
    sprite: am5.Label.new(root, {
      text: "{valueY}",
      centerY: am5.p100, centerX: am5.p50,
      dy: -6, fontSize: 12,
      populateText: true,
    }),
  }));

  const data = [
    { country: "Norway",        value: 2,  color: MAUVE_LITE },
    { country: "Netherlands",   value: 3,  color: MAUVE_LITE },
    { country: "Germany",       value: 4,  color: MAUVE_LITE },
    { country: "Canada",        value: 8,  color: MAUVE_LITE },
    { country: "France",        value: 8,  color: MAUVE_LITE },
    { country: "UK",            value: 10, color: MAUVE_LITE },
    { country: "United States", value: 24, color: MAUVE_DARK },
  ];

  xAxis.data.setAll(data);
  series.data.setAll(data);
  series.appear(1000);
  chart.appear(1000, 100);
}

// ── Chart 2: Preventable Deaths (Donut) ──────────────────────────────
function initPreventable() {
  const root = am5.Root.new("chart-preventable");
  root.setThemes([am5themes_Animated.new(root)]);

  const chart = root.container.children.push(am5percent.PieChart.new(root, {
    innerRadius: am5.percent(65),
    layout: root.horizontalLayout,
  }));

  const series = chart.series.push(am5percent.PieSeries.new(root, {
    valueField: "value",
    categoryField: "label",
    alignLabels: false,
  }));

  series.labels.template.setAll({ forceHidden: true });
  series.ticks.template.setAll({ forceHidden: true });
  series.slices.template.setAll({ stroke: am5.color(0xfaf9f6), strokeWidth: 3 });
  series.get("colors").set("colors", [MAUVE_DARK, MAUVE_LITE]);

  series.data.setAll([
    { label: "Preventable (84%)", value: 84 },
    { label: "Not preventable (16%)", value: 16 },
  ]);

  // Center label
  chart.seriesContainer.children.push(am5.Label.new(root, {
    textAlign: "center",
    centerY: am5.p50, centerX: am5.p50,
    text: "[fontSize:36px fontWeight:300]84%[/]\n[fontSize:11px fill:#999999]preventable[/]",
  }));

  // Legend
  const legend = chart.children.push(am5.Legend.new(root, {
    centerY: am5.p50, y: am5.p50,
    layout: root.verticalLayout,
    paddingLeft: 30,
  }));
  legend.labels.template.setAll({ fontSize: 13 });
  legend.data.setAll(series.dataItems);

  series.appear(1000, 100);
}

// ── Chart 3: Maternal Mortality by Race ──────────────────────────────
function initRace() {
  const root = am5.Root.new("chart-race");
  root.setThemes([am5themes_Animated.new(root)]);

  const chart = root.container.children.push(am5xy.XYChart.new(root, {
    panX: false, panY: false,
    wheelX: "none", wheelY: "none",
    paddingLeft: 0, paddingRight: 10,
    layout: root.verticalLayout,
  }));

  const yRenderer = am5xy.AxisRendererY.new(root, { inversed: false, minGridDistance: 20 });
  yRenderer.labels.template.setAll({ fontSize: 13, fill: am5.color(0x555555) });
  yRenderer.grid.template.setAll({ stroke: am5.color(0xdddddd), strokeWidth: 1, strokeDasharray: [3,3] });

  const yAxis = chart.yAxes.push(am5xy.CategoryAxis.new(root, {
    categoryField: "race",
    renderer: yRenderer,
  }));

  const xRenderer = am5xy.AxisRendererX.new(root, {});
  xRenderer.labels.template.setAll({ fontSize: 12, fill: am5.color(0x666666) });
  xRenderer.grid.template.setAll({ stroke: am5.color(0xdddddd), strokeWidth: 1, strokeDasharray: [3,3] });

  const xAxis = chart.xAxes.push(am5xy.ValueAxis.new(root, {
    min: 0, renderer: xRenderer,
  }));

  xAxis.children.push(am5.Label.new(root, {
    text: "Deaths per 100,000 live births",
    x: am5.p50, centerX: am5.p50,
    fontSize: 11, fill: am5.color(0x999999),
    dy: 8,
  }));

  const series = chart.series.push(am5xy.ColumnSeries.new(root, {
    xAxis, yAxis,
    valueXField: "value",
    categoryYField: "race",
    tooltip: am5.Tooltip.new(root, { labelText: "{categoryY}: {valueX} per 100k" }),
  }));

  series.columns.template.setAll({
    cornerRadiusTR: 3, cornerRadiusBR: 3,
    strokeOpacity: 0,
    height: am5.percent(55),
  });
  series.columns.template.adapters.add("fill", function(fill, target) {
    return target.dataItem.dataContext.color;
  });

  series.bullets.push(() => am5.Bullet.new(root, {
    locationX: 1,
    sprite: am5.Label.new(root, {
      text: "{valueX}",
      centerY: am5.p50, centerX: 0,
      dx: 8, fontSize: 12,
      populateText: true,
    }),
  }));

  const data = [
    { race: "Hispanic", value: 18.2, color: MAUVE_LITE },
    { race: "White",    value: 19.1, color: MAUVE_LITE },
    { race: "Black",    value: 55.3, color: MAUVE_DARK },
  ];

  yAxis.data.setAll(data);
  series.data.setAll(data);
  series.appear(1000);
  chart.appear(1000, 100);
}

// ── Chart 4: Global Workforce ─────────────────────────────────────────
function initWorkforce() {
  const root = am5.Root.new("chart-workforce");
  root.setThemes([am5themes_Animated.new(root)]);

  const chart = root.container.children.push(am5xy.XYChart.new(root, {
    panX: false, panY: false,
    wheelX: "none", wheelY: "none",
    paddingLeft: 0, paddingRight: 10,
    layout: root.verticalLayout,
  }));

  const xRenderer = am5xy.AxisRendererX.new(root, { minGridDistance: 40 });
  xRenderer.labels.template.setAll({ fontSize: 12, fill: am5.color(0x666666) });
  xRenderer.grid.template.setAll({ stroke: am5.color(0xdddddd), strokeWidth: 1, strokeDasharray: [3,3] });

  const xAxis = chart.xAxes.push(am5xy.CategoryAxis.new(root, {
    categoryField: "category",
    renderer: xRenderer,
  }));

  const yRenderer = am5xy.AxisRendererY.new(root, {});
  yRenderer.labels.template.setAll({ fontSize: 12, fill: am5.color(0x666666) });
  yRenderer.grid.template.setAll({ stroke: am5.color(0xdddddd), strokeWidth: 1, strokeDasharray: [3,3] });

  const yAxis = chart.yAxes.push(am5xy.ValueAxis.new(root, {
    min: 0, max: 100,
    strictMinMax: true,
    renderer: yRenderer,
  }));

  yAxis.children.unshift(am5.Label.new(root, {
    rotation: -90, y: am5.p50, centerX: am5.p50,
    text: "% Women", fontSize: 11, fill: am5.color(0x999999),
  }));

  // 50% reference line
  const range = yAxis.makeDataItem({ value: 50 });
  yAxis.createAxisRange(range);
  range.get("grid").setAll({
    stroke: am5.color(0x999999), strokeWidth: 1, strokeDasharray: [4,4],
  });
  range.get("label").setAll({
    text: "50%", fill: am5.color(0x999999), fontSize: 10,
    location: 1, inside: true, dy: -4,
  });

  const mkSeries = (name, field, color) => {
    const s = chart.series.push(am5xy.ColumnSeries.new(root, {
      name, xAxis, yAxis,
      valueYField: field,
      categoryXField: "category",
      tooltip: am5.Tooltip.new(root, { labelText: `${name}: {valueY}%` }),
    }));
    s.columns.template.setAll({
      width: am5.percent(40),
      cornerRadiusTL: 3, cornerRadiusTR: 3,
      fill: color, stroke: color, strokeOpacity: 0,
    });
    s.bullets.push(() => am5.Bullet.new(root, {
      locationY: 1,
      sprite: am5.Label.new(root, {
        text: "{valueY}%",
        centerY: am5.p100, centerX: am5.p50,
        dy: -6, fontSize: 11,
        populateText: true,
      }),
    }));
    return s;
  };

  const seriesW = mkSeries("Women", "women", MAUVE_DARK);
  const seriesM = mkSeries("Men",   "men",   NEUTRAL);

  const legend = chart.children.push(am5.Legend.new(root, {
    centerX: am5.p50, x: am5.p50,
  }));
  legend.labels.template.setAll({ fontSize: 12 });
  legend.data.setAll([seriesW, seriesM]);

  const data = [
    { category: "Unpaid Labor",      women: 75, men: 25 },
    { category: "Low-wage Workers",  women: 60, men: 40 },
    { category: "Senior Management", women: 28, men: 72 },
  ];

  xAxis.data.setAll(data);
  seriesW.data.setAll(data);
  seriesM.data.setAll(data);
  seriesW.appear(1000);
  seriesM.appear(1200);
  chart.appear(1000, 100);
}
</script>

<!-- ── Tab switching + bar animation ─────────────────────────────────── -->
<script is:inline>
// Tabs
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.dataset-view').forEach(v => v.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + tab).classList.add('active');
    animateBars(document.getElementById('tab-' + tab));
  });
});

// Animate bar fills
function animateBars(container) {
  container.querySelectorAll('.bar-fill').forEach(bar => {
    bar.style.width = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        bar.style.width = bar.style.getPropertyValue('--pct') || bar.getAttribute('style').match(/--pct:([^;]+)/)?.[1] || '0';
      });
    });
  });
}

// Init bars on first visible tab
animateBars(document.getElementById('tab-mortality'));

// Also trigger on tab that becomes visible via IntersectionObserver
const explorerObs = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) {
    animateBars(document.querySelector('.dataset-view.active'));
    explorerObs.disconnect();
  }
}, { threshold: 0.1 });
const explorer = document.querySelector('.explorer');
if (explorer) explorerObs.observe(explorer);
</script>

</Base>
