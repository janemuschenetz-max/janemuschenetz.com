<!-- ── SVG animation ──────────────────────────────────────────────────── -->
<script is:inline>
(function () {
  // ── SVG arc sector path builder ──────────────────────────────────────
  function sectorPath(cx, cy, r, startDeg, endDeg) {
    var span = endDeg - startDeg;
    if (Math.abs(span) < 0.05) {
      var s0 = startDeg * Math.PI / 180;
      return 'M ' + cx + ' ' + cy + ' L ' + (cx + r * Math.cos(s0)).toFixed(2) + ' ' + (cy + r * Math.sin(s0)).toFixed(2) + ' Z';
    }
    var s = startDeg * Math.PI / 180;
    var e = endDeg   * Math.PI / 180;
    var x1 = (cx + r * Math.cos(s)).toFixed(2);
    var y1 = (cy + r * Math.sin(s)).toFixed(2);
    var x2 = (cx + r * Math.cos(e)).toFixed(2);
    var y2 = (cy + r * Math.sin(e)).toFixed(2);
    var large = (Math.abs(span) > 180) ? 1 : 0;
    return 'M ' + cx + ' ' + cy + ' L ' + x1 + ' ' + y1 + ' A ' + r + ' ' + r + ' 0 ' + large + ' 1 ' + x2 + ' ' + y2 + ' Z';
  }

  // ── Collect targets ───────────────────────────────────────────────────
  var targets = [];
  var panel = document.querySelector('#panel-mom');
  if (!panel) return;

  // SVG midpoint — left = first M (group 0), pie = O (group 1), right = last M (group 2)
  var MID = 5312;

  panel.querySelectorAll('.mt-bar').forEach(function (rect) {
    var h = parseFloat(rect.getAttribute('height'));
    var y = parseFloat(rect.getAttribute('y'));
    var x = parseFloat(rect.getAttribute('x'));
    var group = x < MID ? 0 : 2;
    targets.push({ el: rect, kind: 'v', targetH: h, bottom: y + h, group: group });
    rect.setAttribute('height', 0);
    rect.setAttribute('y', y + h);
  });

  panel.querySelectorAll('.mt-pie').forEach(function (path) {
    var cx    = parseFloat(path.dataset.cx);
    var cy    = parseFloat(path.dataset.cy);
    var r     = parseFloat(path.dataset.r);
    var start = parseFloat(path.dataset.start);
    var end   = parseFloat(path.dataset.end);
    targets.push({ el: path, kind: 'pie', cx: cx, cy: cy, r: r, start: start, end: end, group: 1 });
    path.setAttribute('d', sectorPath(cx, cy, r, start, start));
  });

  panel.querySelectorAll('.mt-path-bar').forEach(function (path) {
    var bb = path.getBBox();
    var bottom = bb.y + bb.height;
    var startX = parseFloat((path.getAttribute('d').match(/M([\d.]+)/) || [])[1] || 0);
    var group = startX < MID ? 0 : 2;
    targets.push({ el: path, kind: 'path', bottom: bottom, group: group });
    path.setAttribute('transform', 'translate(0,' + bottom + ') scale(1,0) translate(0,' + (-bottom) + ')');
  });

  // ── Stanza fade-in setup ──────────────────────────────────────────────
  var stanzaGroups = [];
  for (var n = 1; n <= 5; n++) {
    var els = panel.querySelectorAll('.mt-stanza-' + n);
    stanzaGroups.push(els);
  }

  // ── Animator: groups animate in turn — first M (0), O (1), last M (2) ─
  function animate() {
    var t0 = null;
    var dur = 1400;   // duration per group (ms)
    var gap = 300;    // pause between groups (ms)
    var groupDelay = [0, dur + gap, (dur + gap) * 2];
    function step(ts) {
      if (!t0) t0 = ts;
      var elapsed = ts - t0;
      var allDone = true;
      targets.forEach(function (item) {
        var local = elapsed - groupDelay[item.group];
        if (local <= 0) { allDone = false; return; }
        var p = Math.min(local / dur, 1);
        if (p < 1) allDone = false;
        var e = 1 - Math.pow(1 - p, 3);
        if (item.kind === 'v') {
          var h = item.targetH * e;
          item.el.setAttribute('height', h);
          item.el.setAttribute('y', item.bottom - h);
        } else if (item.kind === 'pie') {
          var currentEnd = item.start + (item.end - item.start) * e;
          item.el.setAttribute('d', sectorPath(item.cx, item.cy, item.r, item.start, currentEnd));
        } else if (item.kind === 'path') {
          item.el.setAttribute('transform', 'translate(0,' + item.bottom + ') scale(1,' + e + ') translate(0,' + (-item.bottom) + ')');
        }
      });
      if (!allDone) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);

    // Fade in each stanza group in order, 2 seconds apart
    stanzaGroups.forEach(function (els, i) {
      setTimeout(function () {
        els.forEach(function (g) { g.style.opacity = '1'; });
      }, i * 2000);
    });
  }

  // ── IntersectionObserver ──────────────────────────────────────────────
  if (!targets.length && !stanzaGroups.some(function(g) { return g.length; })) return;
  var svg = panel.querySelector('svg');
  if (!svg) return;
  var obs = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting) {
      obs.disconnect();
      animate();
    }
  }, { threshold: 0.15 });
  obs.observe(svg);
})();
</script>


<!-- ── Tab switching + bar animation ─────────────────────────────────── -->
<script is:inline>
// Tabs
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.dataset-view').forEach(v => v.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + tab).classList.add('active');
    animateBars(document.getElementById('tab-' + tab));
  });
});

// Animate bar fills
function animateBars(container) {
  container.querySelectorAll('.bar-fill').forEach(bar => {
    bar.style.width = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        bar.style.width = bar.style.getPropertyValue('--pct') || bar.getAttribute('style').match(/--pct:([^;]+)/)?.[1] || '0';
      });
    });
  });
}

// Init bars on first visible tab
animateBars(document.getElementById('tab-mortality'));

// Also trigger on tab that becomes visible via IntersectionObserver
const explorerObs = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) {
    animateBars(document.querySelector('.dataset-view.active'));
    explorerObs.disconnect();
  }
}, { threshold: 0.1 });
const explorer = document.querySelector('.explorer');
if (explorer) explorerObs.observe(explorer);
</script>

