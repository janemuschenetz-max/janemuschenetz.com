---
import Base from '../../layouts/Base.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

function loadSvg(file: string) {
  return readFileSync(join(process.cwd(), file), 'utf-8')
    .replace(/<\?xml[^?]*\?>/g, '')
    .replace(/<!DOCTYPE[^>]*>/g, '')
    .replace(/MillerText-Roman/g, 'miller-text')
    .replace(/MillerText-Italic/g, 'miller-text')
    .trim();
}
const momSvg = loadSvg('src/assets/mom2.svg');
---

<style>
  .live-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-sm);
  }
  .live-hero .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
  .live-hero .eyebrow a { color: inherit; text-decoration: none; }
  .live-hero .eyebrow a:hover { text-decoration: underline; }
  .live-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2px 8px;
    margin-left: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-secondary);
  }

  /* ── Animated SVG poem ──────────────────────────────────── */
  .poem-section { padding: var(--space-md) 0 var(--space-lg); }
  .mom-svg-panel { width: 100%; overflow: hidden; }
  .mom-svg-panel svg { width: 100%; height: auto; display: block; }

  /* Stanzas start hidden; JS adds opacity:1 via inline style.
     :global() needed because these live inside an inlined SVG Fragment. */
  :global(.mt-stanza-1), :global(.mt-stanza-2), :global(.mt-stanza-3),
  :global(.mt-stanza-4), :global(.mt-stanza-5) {
    opacity: 0;
    transition: opacity 1s ease;
  }

  /* ── Explorer section ───────────────────────────────────── */
  .explore {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) 0 var(--space-md);
  }
  .explore h2 {
    margin-bottom: 0.25rem;
  }
  .explore-intro {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    max-width: 560px;
  }
  .dataset-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .tab-btn {
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    padding: 6px 14px;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .tab-btn:hover,
  .tab-btn.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }
  .dataset-view { display: none; }
  .dataset-view.active { display: block; }
  .data-table-wrap {
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    font-family: var(--font-body);
  }
  .data-table th {
    text-align: left;
    font-weight: 500;
    border-bottom: 1px solid var(--color-text);
    padding: 6px 12px 6px 0;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }
  .data-table td {
    padding: 8px 12px 8px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .data-table tr:last-child td { border-bottom: none; }
  .bar-cell { width: 40%; }
  .bar-track {
    background: var(--color-bg-alt);
    border-radius: 2px;
    height: 10px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: #c4a8bc;
    border-radius: 2px;
    width: 0;
    transition: width 0.8s ease;
  }
  .source-note {
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
    line-height: 1.5;
  }

  /* ── Additional Resources ───────────────────────────────────── */
  .additional-resources {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
  }
  .additional-resources h3 {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
    font-weight: 500;
  }
  .resource-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .resource-list li {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.4rem;
  }
  .resource-list li a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .resource-list li a:hover {
    color: var(--color-text);
  }
  .resource-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-sm) 0;
  }

  /* ── About ──────────────────────────────────────────────── */
  .poem-about {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }

</style>

<Base title="100% Mom (Live) — Jane Muschenetz" description="An animated, interactive data poem on maternal mortality and workforce inequality.">

  <!-- Hero -->
  <section class="live-hero">
    <div class="container">
      <p class="eyebrow"><a href="/visual-data-poetry">← Visual &amp; Data Poetry</a></p>
      <h1 class="page-hero__title">100% Mom, a PowerPoint poem about women and labor <span class="live-badge">Interactive</span></h1>
      <p class="page-hero__subtitle" style="max-width:none;font-style:italic;">from <em>POWER POINT</em>, Winner of the 2025 National Press Women Communications Prize</p>
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        <span style="font-weight:500;color:var(--color-text);">Buy→</span> <a href="https://www.amazon.com/Power-Point-Jane-Muschenetz/dp/1962405028/ref=sr_1_1?crid=GCKRJXP4AAPK&dib=eyJ2IjoiMSJ9.D5VuMTeV0OLUxn7L0cIHYrSnbrahVWtvaNEgwMsp5Go.8hBn07mxqiHgYFXJhV1L51QiirTsXjRmdG91xX8ZoT8&dib_tag=se&keywords=jane+muschenetz&qid=1773765718&sprefix=muschene%2Caps%2C262&sr=8-1" target="_blank" rel="noopener noreferrer">Amazon</a> · <a href="https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/" target="_blank" rel="noopener noreferrer">Sheila-Na-Gig</a> · <a href="https://thepoetryshop.com/products/power-point?_pos=1&_sid=27f225e2f&_ss=r" target="_blank" rel="noopener noreferrer">The Poetry Shop</a>
      </p>
