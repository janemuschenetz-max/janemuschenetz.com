---
import Base from '../../layouts/Base.astro';
---

<style>
  .live-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-sm);
  }
  .live-hero .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
  .live-hero .eyebrow a { color: inherit; text-decoration: none; }
  .live-hero .eyebrow a:hover { text-decoration: underline; }
  .live-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2px 8px;
    margin-left: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-secondary);
  }

  /* ── Gun poem container ─────────────────────────────────── */
  .gun-section { padding: 0.5rem 0 var(--space-lg); }

  .gun-epigraph {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(0.88rem, 1.4vw, 1rem);
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    max-width: 640px;
  }

  .pb-svg-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
  }
  .pb-svg-container svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .gun-source {
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    margin-top: 0.75rem;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── About ──────────────────────────────────────────────── */
  .poem-about {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }

  /* ── Explore ────────────────────────────────────────────── */
  .explore {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }
  .explore h2 { margin-bottom: 0.25rem; }
  .explore-intro {
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    max-width: 560px;
    margin-bottom: var(--space-lg);
  }

  /* Chart panels */
  .chart-panel {
    background: var(--color-bg-alt);
    border-radius: 4px;
    padding: var(--space-md) var(--space-md) var(--space-sm);
    margin-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .chart-panel.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .chart-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    margin-bottom: var(--space-sm);
  }
  .chart-note {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
    line-height: 1.5;
  }
  #explore-pb-homicide { width: 100%; height: 520px; }
  #explore-pb-intl  { width: 100%; height: 520px; }
  #explore-pb-child { width: 100%; height: 240px; }

  /* Big-number stat block */
  .stat-block {
    padding: var(--space-md) 0 var(--space-sm);
  }
  .stat-total {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .stat-subtitle {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-top: 0.4rem;
    margin-bottom: var(--space-md);
  }
  .stat-bars { max-width: 560px; }
  .stat-row {
    display: grid;
    grid-template-columns: 160px 1fr 130px;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text);
    font-family: var(--font-body);
  }
  .stat-track {
    height: 10px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }
  .stat-fill {
    height: 100%;
    border-radius: 2px;
  }
  .stat-pct {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    #explore-pb-intl  { height: 400px; }
    #explore-pb-child { height: 240px; }
    .stat-row { grid-template-columns: 130px 1fr; }
    .stat-pct { display: none; }
  }
</style>

