<script is:inline>
// ── POEM CHART: animate original SVG data bars (expand width from 0) ──
(function () {
  var bars = document.querySelectorAll('.pb-data-bar');
  if (!bars.length) return;

  // Collect rects and their natural widths; start at 0
  var targets = [];
  bars.forEach(function (g) {
    var rect = g.querySelector('rect');
    if (!rect) return;
    var origWidth = parseFloat(rect.getAttribute('width'));
    targets.push({ rect: rect, origWidth: origWidth });
    rect.setAttribute('width', '0');
  });

  function animateBars() {
    var start = null;
    var duration = 1600;
    function step(ts) {
      if (!start) start = ts;
      var p = Math.min((ts - start) / duration, 1);
      var e = 1 - Math.pow(1 - p, 3); // ease-out cubic
      targets.forEach(function (item) {
        item.rect.setAttribute('width', String(item.origWidth * e));
      });
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  var svg = document.querySelector('.pb-svg-container svg');
  if (!svg) return;
  var observer = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting) {
      observer.disconnect();
      animateBars();
    }
  }, { threshold: 0.2 });
  observer.observe(svg);
})();

// ── Scroll-triggered explore chart initialization ──────────────────────
(function () {
  var panels = {
    "panel-pb-homicide": initHomicide,
    "panel-pb-intl":  initIntl,
    "panel-pb-child": initChild,
  };
  var initialized = {};
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        var id = entry.target.id;
        entry.target.classList.add("visible");
        if (!initialized[id] && panels[id]) {
          initialized[id] = true;
          panels[id]();
        }
      }
    });
  }, { threshold: 0.15 });
  Object.keys(panels).forEach(function (id) {
    var el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  // ── EXPLORE CHART 0: Firearm Homicides Only (matches poem) ────────────
  function initHomicide() {
  var root = am5.Root.new("explore-pb-homicide");
  root.setThemes([am5themes_Animated.new(root)]);

  var chart = root.container.children.push(am5xy.XYChart.new(root, {
    panX: false, panY: false,
    paddingLeft: 0, paddingRight: 65, paddingTop: 10, paddingBottom: 10,
  }));

  var yRenderer = am5xy.AxisRendererY.new(root, { inversed: true, minGridDistance: 20 });
  yRenderer.labels.template.setAll({ fontSize: 11, fill: am5.color(0x555555) });
  yRenderer.grid.template.setAll({ visible: false });

  var yAxis = chart.yAxes.push(am5xy.CategoryAxis.new(root, {
    categoryField: "country", renderer: yRenderer,
  }));

  var xRenderer = am5xy.AxisRendererX.new(root, {});
  xRenderer.labels.template.setAll({ fontSize: 11, fill: am5.color(0x666666) });
  xRenderer.grid.template.setAll({ stroke: am5.color(0xdddddd), strokeWidth: 1, strokeDasharray: [3, 3] });

  var xAxis = chart.xAxes.push(am5xy.ValueAxis.new(root, {
    min: 0, renderer: xRenderer,
  }));
  xAxis.children.push(am5.Label.new(root, {
    text: "Firearm homicide deaths per 100,000 population",
    x: am5.p50, centerX: am5.p50, fontSize: 11, fill: am5.color(0x999999), dy: 8,
  }));

  var series = chart.series.push(am5xy.ColumnSeries.new(root, {
    xAxis, yAxis, valueXField: "value", categoryYField: "country",
    tooltip: am5.Tooltip.new(root, { labelText: "{country}: {valueX} per 100K" }),
  }));
  series.columns.template.setAll({
    cornerRadiusTR: 2, cornerRadiusBR: 2, strokeOpacity: 0, height: am5.percent(60),
  });
  series.columns.template.adapters.add("fill", function (fill, target) {
