---
import Base from '../../layouts/Base.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

function loadSvg(file: string) {
  return readFileSync(join(process.cwd(), file), 'utf-8')
    .replace(/<\?xml[^?]*\?>/g, '')
    .replace(/<!DOCTYPE[^>]*>/g, '')
    .replace(/MillerText-Roman/g, 'miller-text')
    .replace(/MillerText-Italic/g, 'miller-text')
    .trim();
}
const exSvg = loadSvg('src/assets/exclamation.svg');
---

<style>
  .live-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-sm);
  }
  .live-hero .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
  .live-hero .eyebrow a { color: inherit; text-decoration: none; }
  .live-hero .eyebrow a:hover { text-decoration: underline; }
  .live-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2px 8px;
    margin-left: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-secondary);
  }

  /* ── SVG poem ───────────────────────────────────────────── */
  .poem-section { padding: 0; }
  .ex-svg-panel { width: 100%; background: rgb(237, 30, 36); }
  .ex-svg-panel svg { width: 100%; height: auto; display: block; }

  /* Text lines start hidden; scroll-driven JS reveals them.
     :global() because these live inside an inlined SVG Fragment. */
  :global(.ex-line) {
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  /* ── About ──────────────────────────────────────────────── */
  .poem-about {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }
</style>

<Base title="Exclamation Point (Live) — Jane Muschenetz" description="An interactive poem on the exclamation point — from emoji overuse to active shooter drill instructions.">

  <!-- Hero -->
  <section class="live-hero">
    <div class="container">
      <p class="eyebrow"><a href="/visual-data-poetry">&larr; Visual &amp; Data Poetry</a></p>
      <h1 class="page-hero__title">Exclamation Point <span class="live-badge">Interactive</span></h1>
      <p class="page-hero__subtitle" style="max-width:none;font-style:italic;">from <em>POWER POINT</em> (Sheila-Na-Gig Editions, 2024)</p>
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        <a href="/poems/exclamation-point" class="link-underline">View original static version &rarr;</a>
      </p>
    </div>
  </section>

  <!-- SVG poem: lines reveal in sequence when SVG enters view -->
  <section class="poem-section">
    <div class="ex-svg-panel" id="panel-ex">
      <Fragment set:html={exSvg} />
    </div>
  </section>

  <!-- About -->
  <section class="poem-about">
    <div class="container">
      <h2>About This Poem</h2>
      <p>'Exclamation Point' moves from the punctuation mark's overuse in digital culture to its most urgent application — active shooter drill instructions given to children. The poem's shape enacts its subject: the exclamation point itself, from emphatic emoji to "RUN. HIDE. FIGHT."</p>
    </div>
  </section>

</Base>

<script is:inline>
(function () {
  var panel = document.getElementById('panel-ex');
  if (!panel) return;
  var svgEl = panel.querySelector('svg');
  if (!svgEl) return;

  var TOTAL = 21;
  var DELAY = 840; // ms between each line

  var lineEls = [];
  for (var n = 1; n <= TOTAL; n++) {
    lineEls.push(panel.querySelectorAll('.ex-line-' + n));
  }

  function revealAll() {
    lineEls.forEach(function(els, i) {
      setTimeout(function() {
        for (var j = 0; j < els.length; j++) {
          els[j].style.opacity = '1';
        }
      }, i * DELAY);
    });
  }

  var obs = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) {
      obs.disconnect();
      revealAll();
    }
  }, { threshold: 0, rootMargin: '0px 0px -10% 0px' });

  obs.observe(svgEl);
})();
</script>
