---
import Base from '../../layouts/Base.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

function loadSvg(file: string) {
  return readFileSync(join(process.cwd(), file), 'utf-8')
    .replace(/<\?xml[^?]*\?>/g, '')
    .replace(/<!DOCTYPE[^>]*>/g, '')
    .replace(/MillerText-Roman/g, 'miller-text')
    .replace(/MillerText-Italic/g, 'miller-text')
    .trim();
}
const exSvg = loadSvg('src/assets/exclamation.svg');
---

<style>
  .live-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-sm);
  }
  .live-hero .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
  .live-hero .eyebrow a { color: inherit; text-decoration: none; }
  .live-hero .eyebrow a:hover { text-decoration: underline; }
  .live-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2px 8px;
    margin-left: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-secondary);
  }

  /* ── SVG poem ───────────────────────────────────────────── */
  .poem-section { padding: 0; }
  .ex-svg-panel { width: 100%; background: rgb(237, 30, 36); }
  :global(.ex-svg-panel svg) { width: 80% !important; height: auto !important; display: block; margin: 0 auto; }
  @media (min-width: 768px) {
    :global(.ex-svg-panel svg) { width: 60% !important; }
  }

  /* Text lines start hidden; scroll-driven JS reveals them.
     :global() because these live inside an inlined SVG Fragment. */
  :global(.ex-line) {
    opacity: 0;
    transition: opacity 0.72s ease;
  }

  /* ── About ──────────────────────────────────────────────── */
  .poem-about {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }

  /* ── Explore ─────────────────────────────────────────────── */
  .explore {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }
  .explore-intro {
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    max-width: 560px;
    margin-bottom: var(--space-lg);
  }
  .chart-panel {
    background: var(--color-bg-alt);
    border-radius: 4px;
    padding: var(--space-md) var(--space-md) var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .chart-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    margin-bottom: var(--space-sm);
  }
  .chart-note {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
    line-height: 1.5;
  }
  .stat-block { padding: var(--space-md) 0 var(--space-sm); }
  .stat-total {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .stat-subtitle {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-top: 0.4rem;
    margin-bottom: var(--space-md);
  }
  .stat-bars { max-width: 560px; }
  .stat-row {
    display: grid;
    grid-template-columns: 220px 1fr 80px;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }
  .stat-label { font-size: 0.85rem; color: var(--color-text); }
  .stat-track { height: 10px; background: var(--color-border); border-radius: 2px; overflow: hidden; }
  .stat-fill  { height: 100%; border-radius: 2px; }
  .stat-pct   { font-size: 0.78rem; color: var(--color-text-secondary); }
</style>

<Base title="Exclamation Point (Live) — Jane Muschenetz" description="An interactive poem on the exclamation point — from emoji overuse to active shooter drill instructions.">

  <!-- Hero -->
  <section class="live-hero">
    <div class="container">
      <p class="eyebrow"><a href="/visual-data-poetry">&larr; Visual &amp; Data Poetry</a></p>
      <h1 class="page-hero__title">Exclamation Point <span class="live-badge">Interactive</span></h1>
      <p class="page-hero__subtitle" style="max-width:none;font-style:italic;">from <em>POWER POINT</em>, Winner of the 2025 National Press Women Communications Prize</p>
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        <span style="font-weight:500;color:var(--color-text);">Buy→</span> <a href="https://www.amazon.com/Power-Point-Jane-Muschenetz/dp/1962405028/ref=sr_1_1?crid=GCKRJXP4AAPK&dib=eyJ2IjoiMSJ9.D5VuMTeV0OLUxn7L0cIHYrSnbrahVWtvaNEgwMsp5Go.8hBn07mxqiHgYFXJhV1L51QiirTsXjRmdG91xX8ZoT8&dib_tag=se&keywords=jane+muschenetz&qid=1773765718&sprefix=muschene%2Caps%2C262&sr=8-1" target="_blank" rel="noopener noreferrer">Amazon</a> · <a href="https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/" target="_blank" rel="noopener noreferrer">Sheila-Na-Gig</a> · <a href="https://thepoetryshop.com/products/power-point?_pos=1&_sid=27f225e2f&_ss=r" target="_blank" rel="noopener noreferrer">The Poetry Shop</a>
      </p>
    </div>
  </section>

  <!-- SVG poem: lines reveal in sequence when SVG enters view -->
  <section class="poem-section">
    <div class="ex-svg-panel" id="panel-ex">
      <Fragment set:html={exSvg} />
    </div>
  </section>

  <!-- About -->
  <section class="poem-about">
    <div class="container">
      <h3>About This Poem</h3>
      <p>'Exclamation Point' skewers inadequate approaches to school safety, questioning generational divides and what effective protection looks like. The warning sign shape and erratic font (reminiscent of a ransom note) suggest the feeling of being held hostage, literally and figuratively, in a state of escalating and constant alarm.</p>
      <p class="mt-sm" style="font-size:0.85rem;color:var(--color-text-secondary);">From <a href="https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/" target="_blank" rel="noopener noreferrer"><em>POWER POINT</em></a> (Sheila-Na-Gig Editions, 2024).</p>
    </div>
  </section>

  <!-- Explore the Data -->
  <section class="explore">
    <div class="container">
      <h3>Explore the Data</h3>
      <p class="explore-intro">The numbers behind America's school shooting epidemic — incidents, drills, and how the US compares to every other country.</p>

      <div class="chart-panel">
        <p class="chart-label">School Shooting Incidents, US K-12 Schools — 2018–2023</p>
        <div class="stat-bars">
          <div class="stat-row"><span class="stat-label">2018</span><div class="stat-track"><div class="stat-fill" style="width:27%;background:#B5342A;"></div></div><span class="stat-pct">94</span></div>
          <div class="stat-row"><span class="stat-label">2019</span><div class="stat-track"><div class="stat-fill" style="width:13%;background:#B5342A;"></div></div><span class="stat-pct">45</span></div>
          <div class="stat-row"><span class="stat-label">2020</span><div class="stat-track"><div class="stat-fill" style="width:7%;background:#aaa;"></div></div><span class="stat-pct">23 <em>(schools closed)</em></span></div>
          <div class="stat-row"><span class="stat-label">2021</span><div class="stat-track"><div class="stat-fill" style="width:39%;background:#B5342A;"></div></div><span class="stat-pct">136</span></div>
          <div class="stat-row"><span class="stat-label">2022</span><div class="stat-track"><div class="stat-fill" style="width:54%;background:#B5342A;"></div></div><span class="stat-pct">188</span></div>
          <div class="stat-row"><span class="stat-label">2023</span><div class="stat-track"><div class="stat-fill" style="width:100%;background:#B5342A;"></div></div><span class="stat-pct">348</span></div>
        </div>
        <p class="chart-note">Source: <a href="https://everytown.org/gunfire-on-school-grounds/" target="_blank" rel="noopener">Everytown for Gun Safety, "Gunfire on School Grounds," 2024</a>. Includes all instances of a gun being fired on K-12 school grounds.</p>
      </div>

      <div class="chart-panel">
        <p class="chart-label">Active Shooter Drills — Impact on Students</p>
        <div class="stat-block">
          <div class="stat-total">95%</div>
          <div class="stat-subtitle">of US public schools conduct lockdown drills</div>
          <div class="stat-bars" style="margin-top:1rem;">
            <div class="stat-row"><span class="stat-label">Students scared/upset after a drill</span><div class="stat-track"><div class="stat-fill" style="width:42%;background:#B5342A;"></div></div><span class="stat-pct">42%</span></div>
            <div class="stat-row"><span class="stat-label">Students with trouble sleeping after drill</span><div class="stat-track"><div class="stat-fill" style="width:22%;background:#64748b;"></div></div><span class="stat-pct">22%</span></div>
            <div class="stat-row"><span class="stat-label">Teachers who felt drills increased anxiety</span><div class="stat-track"><div class="stat-fill" style="width:60%;background:#64748b;"></div></div><span class="stat-pct">60%</span></div>
          </div>
        </div>
        <p class="chart-note">Source: <a href="https://nces.ed.gov/" target="_blank" rel="noopener">NCES, "School Survey on Crime and Safety," 2019–20</a>; <a href="https://everytown.org/" target="_blank" rel="noopener">Everytown, "Dangerous Drills," 2023</a>. Since 2000, more than 74 million US children have participated in at least one active shooter drill.</p>
      </div>
    </div>
  </section>

  <section style="border-top: 1px solid var(--color-border); padding: var(--space-md) 0;">
    <div class="container">
      <p style="font-size:0.9rem; color:var(--color-text-secondary);">Also on gun violence: <a href="/poems/point-blank-live" style="color:var(--color-text);">Point Blank →</a></p>
    </div>
  </section>

</Base>

<script is:inline>
(function () {
  var panel = document.getElementById('panel-ex');
  if (!panel) return;
  var svgEl = panel.querySelector('svg');
  if (!svgEl) return;

  var TOTAL = 21;
  var DELAY = 1120; // ms between each line

  var lineEls = [];
  for (var n = 1; n <= TOTAL; n++) {
    lineEls.push(panel.querySelectorAll('.ex-line-' + n));
  }

  var timers = [];

  function showAll() {
    timers.forEach(function(t) { clearTimeout(t); });
    timers = [];
    lineEls.forEach(function(els) {
      for (var j = 0; j < els.length; j++) {
        els[j].style.opacity = '1';
      }
    });
  }

  function revealAll() {
    lineEls.forEach(function(els, i) {
      timers.push(setTimeout(function() {
        for (var j = 0; j < els.length; j++) {
          els[j].style.opacity = '1';
        }
      }, i * DELAY));
    });
  }

  panel.addEventListener('click', showAll);

  var obs = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) {
      obs.disconnect();
      revealAll();
    }
  }, { threshold: 0, rootMargin: '0px 0px -10% 0px' });

  obs.observe(svgEl);
})();
</script>
