---
import Base from '../../layouts/Base.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

// Inline both SVGs at build time (strip XML declaration & DOCTYPE)
function loadSvg(file: string) {
  return readFileSync(join(process.cwd(), file), 'utf-8')
    .replace(/<\?xml[^?]*\?>/g, '')
    .replace(/<!DOCTYPE[^>]*>/g, '')
    .replace(/MillerText-Roman/g, 'miller-text')
    .replace(/MillerText-Italic/g, 'miller-text')
    .trim();
}
const meSvg  = loadSvg('src/assets/me2.svg');
const tooSvg = loadSvg('src/assets/too2.svg');
---

<style>
  .live-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-sm);
  }
  .live-hero .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
  .live-hero .eyebrow a { color: inherit; text-decoration: none; }
  .live-hero .eyebrow a:hover { text-decoration: underline; }
  .live-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2px 8px;
    margin-left: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-secondary);
  }

  /* ── SVG poem stanza text — hidden until animated in ────── */
  :global(.mt-stanza-m),
  :global(.mt-stanza-e),
  :global(.mt-stanza-final),
  :global(.mt-stanza-isnt) {
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  /* ── SVG charts stacked vertically ──────────────────────── */
  .poem-section { padding: var(--space-md) 0 var(--space-lg); }

  .mt-svg-stack {
    width: 100%;
  }

  /* Each chart panel takes full width */
  .mt-svg-panel {
    width: 100%;
    overflow: hidden;
  }
  .mt-svg-panel svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── About ──────────────────────────────────────────────── */
  .poem-about {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }
  .poem-about p + p {
    margin-top: 1rem;
  }

  /* ── Explore section ─────────────────────────────────────── */
  .explore {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0 var(--space-md);
  }
  .explore h3 { margin-bottom: 0.25rem; }
  .explore-intro {
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    max-width: 560px;
    margin-bottom: var(--space-lg);
  }

  /* Chart panels */
  .chart-panel {
    background: var(--color-bg-alt);
    border-radius: 4px;
    padding: var(--space-md) var(--space-md) var(--space-sm);
    margin-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .chart-panel.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .chart-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    margin-bottom: var(--space-sm);
  }
  .chart-note {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
    line-height: 1.5;
  }
  #chart-mt-prevalence { width: 100%; height: 320px; }

  /* Big-number stat block */
  .stat-block {
    padding: var(--space-md) 0 var(--space-sm);
  }
  .stat-total {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .stat-subtitle {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-top: 0.4rem;
    max-width: 480px;
  }
  .stat-bars { max-width: 560px; }
  .stat-row {
    display: grid;
    grid-template-columns: 150px 1fr 80px;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text);
    font-family: var(--font-body);
  }
  .stat-track {
    height: 10px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }
  .stat-fill {
    height: 100%;
    border-radius: 2px;
  }
  .stat-pct {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    #chart-mt-prevalence { height: 260px; }
    .stat-row { grid-template-columns: 130px 1fr; }
    .stat-pct { display: none; }
  }
</style>

<Base title="#ME TOO (Live) — Jane Muschenetz" description="An animated, interactive data poem on sexual violence prevalence, underreporting, and the shared economic burden.">

  <!-- Hero -->
  <section class="live-hero">
    <div class="container">
      <p class="eyebrow"><a href="/visual-data-poetry">&larr; Visual &amp; Data Poetry</a></p>
      <h1 class="page-hero__title">#ME TOO, a Point of Consensus <span class="live-badge">Interactive</span></h1>
      <p class="page-hero__subtitle" style="max-width:none;font-style:italic;">from <a href="https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/" target="_blank" rel="noopener noreferrer"><em>POWER POINT</em> (Sheila-Na-Gig Editions, 2024)</a></p>
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        <a href="/poems/metoo" class="link-underline">View original static version &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Animated SVG charts stacked vertically -->
  <section class="poem-section">
    <div class="container">
      <div class="mt-svg-stack">
        <!-- M + E charts — bars animated by JS -->
        <div class="mt-svg-panel" id="panel-me">
          <Fragment set:html={meSvg} />
        </div>
        <!-- T + O + O charts -->
        <div class="mt-svg-panel" id="panel-too">
          <Fragment set:html={tooSvg} />
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="poem-about">
    <div class="container">
      <h3>About This Poem</h3>
      <p>#ME TOO renders real-world statistics on sexual violence (SV) and prevention into letters through data charts created in Microsoft PowerPoint. The poem is an homage to the ME TOO movement (popularized via social media) to end SV complicity and victim shaming. The title, a statement of inherent solidarity and consensus, is belied by the poem&rsquo;s subtext, acknowledging SV as a politicized and polarizing issue. The stark statistics contrast with backlash claims that SV is not a prevalent problem, &ldquo;the pendulum has swung too far the other way,&rdquo; and that it is only an issue for certain genders or sides of the political spectrum.</p>
      <p>The visual staging of the poem echoes a scientific paper, with boxed and numbered text explicating the data. The pink and blue of the large chart-based letters call attention to SV&rsquo;s cross-gender impact. The poem questions the perceived acceptance of a chilling status quo.</p>
    </div>
  </section>

  <!-- Explore the Data -->
  <section class="explore">
    <div class="container">
      <h3>Explore the Data</h3>
      <p class="explore-intro">The data behind the five charts of #METOO &mdash; prevalence, reporting rates, and the shared economic burden.</p>

      <div class="chart-panel" id="panel-mt-prevalence">
        <p class="chart-label">Sexual Violence Prevalence &mdash; Lifetime Victimization Rates, US</p>
        <div id="chart-mt-prevalence"></div>
        <p class="chart-note">Source: CDC, &ldquo;Preventing Sexual Violence&rdquo; Fast Facts, 2023. 1 in 4 women and 1 in 26 men experience completed or attempted rape in their lifetime. An estimated 81% of women and 35% of men report PTSD or other lasting impacts.</p>
      </div>

      <div class="chart-panel visible" id="panel-mt-reporting">
        <p class="chart-label">Reporting Rate &mdash; Sexual Violence Cases Reported to Police</p>
        <div class="stat-block">
          <div class="stat-total">310</div>
          <div class="stat-subtitle">out of every 1,000 sexual assaults reported to police</div>
          <div class="stat-bars" style="margin-top:var(--space-md);">
            <div class="stat-row">
              <span class="stat-label">Reported</span>
              <div class="stat-track"><div class="stat-fill" style="width:31%;background:#b4c7e7;"></div></div>
              <span class="stat-pct">31% &mdash; 310 per 1,000</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Not reported</span>
              <div class="stat-track"><div class="stat-fill" style="width:69%;background:#d4d0c8;"></div></div>
              <span class="stat-pct">69% &mdash; 690 per 1,000</span>
            </div>
          </div>
        </div>
        <p class="chart-note">Source: RAINN.org, &ldquo;Scope of the Problem,&rdquo; 2020; US Dept. of Justice, Bureau of Justice Statistics, Criminal Victimization Report, 2022.</p>
      </div>

      <div class="chart-panel visible" id="panel-mt-economic">
        <p class="chart-label">Lifetime Economic Burden of Rape &mdash; Cost Breakdown per Victim</p>
        <div class="stat-block">
          <div class="stat-total">$122,461</div>
          <div class="stat-subtitle">lifetime economic cost per rape victim &mdash; $6 trillion nationally</div>
          <div class="stat-bars" style="margin-top:var(--space-md);">
            <div class="stat-row">
              <span class="stat-label">Lost productivity</span>
              <div class="stat-track"><div class="stat-fill" style="width:52%;background:#ffb7ff;"></div></div>
              <span class="stat-pct">52%</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Medical costs</span>
              <div class="stat-track"><div class="stat-fill" style="width:39%;background:#b4c7e7;"></div></div>
              <span class="stat-pct">39%</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Legal &amp; other</span>
              <div class="stat-track"><div class="stat-fill" style="width:9%;background:#d4d0c8;"></div></div>
              <span class="stat-pct">9%</span>
            </div>
          </div>
        </div>
        <p class="chart-note">Source: C. Peterson et al., &ldquo;Lifetime Economic Burden of Rape Among US Adults,&rdquo; American Journal of Preventive Medicine, 2017.</p>
      </div>
    </div>
  </section>

  <!-- Additional Resources -->
  <section style="border-top: 1px solid var(--color-border); padding: var(--space-lg) 0;">
    <div class="container">
      <h3>Additional Resources</h3>
      <div class="poem-footnotes" style="border-top: none; padding-top: 0;">
        <ul>
          <li><a href="https://bjs.ojp.gov/document/cv22.pdf" target="_blank" rel="noopener noreferrer">Criminal Victimization Report</a>, US Dept of Justice, Bureau of Justice Statistics, 2022</li>
          <li><a href="https://pubmed.ncbi.nlm.nih.gov/28153649/" target="_blank" rel="noopener noreferrer">&ldquo;Lifetime Economic Burden of Rape Among US Adults,&rdquo;</a> Estimated economic cost applied the CDC 2014 lifetime cost of $122.5K per victim to all rape victims (adult and minor) based on 2022 estimates from Dept of Justice.</li>
          <li><a href="https://www.cdc.gov/sexual-violence/site.html#gen" target="_blank" rel="noopener noreferrer">&ldquo;Preventing Sexual Violence,&rdquo;</a> Fast Facts, CDC, 2023</li>
          <li>Pilot program effectiveness sourced from the <a href="https://www.cdc.gov/violence-prevention/media/pdf/resources-for-action/SV-Prevention-Resource_508.pdf" target="_blank" rel="noopener noreferrer">&ldquo;Sexual Violence Prevention Resource for Action Report,&rdquo;</a> CDC, 2016</li>
        </ul>
      </div>
    </div>
  </section>

  <script is:inline>
  (function () {
    var DUR = 3200; // 2× slower

    // ── Collect vertical bar targets ──────────────────────────────────────
    function collectV(selector) {
      var targets = [];
      document.querySelectorAll(selector).forEach(function (rect) {
        var h = parseFloat(rect.getAttribute('height'));
        var y = parseFloat(rect.getAttribute('y'));
        targets.push({ el: rect, kind: 'v', targetH: h, bottom: y + h });
        rect.setAttribute('height', 0);
        rect.setAttribute('y', y + h);
      });
      return targets;
    }

    // ── Collect horizontal bar targets ────────────────────────────────────
    function collectH(selector) {
      var targets = [];
      document.querySelectorAll(selector).forEach(function (rect) {
        var w = parseFloat(rect.getAttribute('width'));
        targets.push({ el: rect, kind: 'h', targetW: w });
        rect.setAttribute('width', 0);
      });
      return targets;
    }

    // ── Animator with optional completion callback ────────────────────────
    function animate(targets, onDone) {
      var t0 = null;
      function step(ts) {
        if (!t0) t0 = ts;
        var p = Math.min((ts - t0) / DUR, 1);
        var e = 1 - Math.pow(1 - p, 3); // ease-out cubic
        targets.forEach(function (item) {
          if (item.kind === 'v') {
            var h = item.targetH * e;
            item.el.setAttribute('height', h);
            item.el.setAttribute('y', item.bottom - h);
          } else if (item.kind === 'h') {
            item.el.setAttribute('width', item.targetW * e);
          }
        });
        if (p < 1) {
          requestAnimationFrame(step);
        } else if (onDone) {
          onDone();
        }
      }
      requestAnimationFrame(step);
    }

    // ── Helper: fade in all SVG elements with a given class ──────────────
    function fadeInStanza(cls) {
      document.querySelectorAll('.' + cls).forEach(function (el) {
        el.style.opacity = '1';
      });
    }

    // ── Collect targets upfront ───────────────────────────────────────────
    var mTargets   = collectV('#panel-me .mt-bar');
    var eTargets   = collectH('#panel-me .mt-bar-h');
    var tooTargets = collectV('#panel-too .mt-bar');

    // ── panel-me: M bars + M text → E bars + E text ───────────────────────
    var mePanel = document.getElementById('panel-me');
    if (mePanel) {
      var meObs = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          meObs.disconnect();
          fadeInStanza('mt-stanza-m');
          animate(mTargets, function () {
            fadeInStanza('mt-stanza-e');
            animate(eTargets);
          });
        }
      }, { threshold: 0 });
      meObs.observe(mePanel);
    }

    // ── panel-too: T bars + first stanza → T done → final stanza ─────────
    var tooPanel = document.getElementById('panel-too');
    if (tooPanel) {
      var tooObs = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          tooObs.disconnect();
          fadeInStanza('mt-stanza-final');
          animate(tooTargets, function () {
            fadeInStanza('mt-stanza-isnt');
          });
        }
      }, { threshold: 0 });
      tooObs.observe(tooPanel);
    }
  })();
  </script>

  <!-- AMCharts 5 — explore charts -->
  <script is:inline src="https://cdn.amcharts.com/lib/5/index.js"></script>
  <script is:inline src="https://cdn.amcharts.com/lib/5/xy.js"></script>
<script is:inline src="https://cdn.amcharts.com/lib/5/themes/Animated.js"></script>

  <script is:inline>
  (function () {
    var BLUE   = am5.color(0xb4c7e7);   // from SVG palette
    var PINK   = am5.color(0xffb7ff);   // from SVG palette
    var DARK   = am5.color(0x1A1A1A);
    var MUTED  = am5.color(0xd4d0c8);
    var BG     = am5.color(0xF0EFEB);

    // ── Scroll-triggered initialization ───────────────────────────────
    var panels = {
      "panel-mt-prevalence": initPrevalence,
    };
    var initialized = {};

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var id = entry.target.id;
          entry.target.classList.add("visible");
          if (!initialized[id] && panels[id]) {
            initialized[id] = true;
            panels[id]();
          }
        }
      });
    }, { threshold: 0.15 });

    Object.keys(panels).forEach(function (id) {
      var el = document.getElementById(id);
      if (el) observer.observe(el);
    });

    // ── Chart 1: Prevalence ─────────────────────────────────────────
    function initPrevalence() {
      var root = am5.Root.new("chart-mt-prevalence");
      root.setThemes([am5themes_Animated.new(root)]);

      var chart = root.container.children.push(am5xy.XYChart.new(root, {
        panX: false, panY: false,
        wheelX: "none", wheelY: "none",
        paddingLeft: 0, paddingRight: 80, paddingTop: 20,
      }));

      var data = [
        { group: "1 in 26 men",   pct: 3.8,  colCfg: { fill: BLUE } },
        { group: "1 in 4 women",  pct: 25.0, colCfg: { fill: PINK } },
      ];

      var xRenderer = am5xy.AxisRendererX.new(root, { minGridDistance: 80 });
      xRenderer.labels.template.setAll({ fontSize: 14, fill: DARK });
      xRenderer.grid.template.setAll({ visible: false });

      var xAxis = chart.xAxes.push(am5xy.CategoryAxis.new(root, {
        categoryField: "group", renderer: xRenderer,
      }));

      var yRenderer = am5xy.AxisRendererY.new(root, {});
      yRenderer.labels.template.setAll({ fontSize: 11, fill: DARK });
      yRenderer.grid.template.setAll({ strokeOpacity: 0.1 });

      var yAxis = chart.yAxes.push(am5xy.ValueAxis.new(root, {
        min: 0, max: 30, strictMinMax: true,
        numberFormat: "#'%'", renderer: yRenderer,
      }));

      yAxis.children.unshift(am5.Label.new(root, {
        rotation: -90, y: am5.p50, centerX: am5.p50,
        text: "Lifetime victimization rate",
        fontSize: 11, fill: am5.color(0x888888),
      }));

      var series = chart.series.push(am5xy.ColumnSeries.new(root, {
        xAxis: xAxis, yAxis: yAxis,
        valueYField: "pct", categoryXField: "group",
        tooltip: am5.Tooltip.new(root, {
          labelText: "{group}: {valueY}%",
          getFillFromSprite: false, autoTextColor: false,
        }),
      }));
      series.get("tooltip").get("background").setAll({ fill: BG, stroke: DARK, strokeWidth: 1 });
      series.get("tooltip").label.setAll({ fill: DARK, fontSize: 13 });

      series.columns.template.setAll({
        cornerRadiusTL: 3, cornerRadiusTR: 3,
        strokeOpacity: 0, width: am5.percent(45),
        templateField: "colCfg",
      });

      series.bullets.push(function () {
        return am5.Bullet.new(root, {
          locationY: 1,
          sprite: am5.Label.new(root, {
            text: "{valueY}%",
            centerY: am5.p100, centerX: am5.p50,
            dy: -10, fontSize: 15, fontWeight: "600",
            fill: DARK, populateText: true,
          }),
        });
      });

      xAxis.data.setAll(data);
      series.data.setAll(data);
      series.appear(1200);
      chart.appear(1000, 100);
    }

  })();
  </script>

</Base>
