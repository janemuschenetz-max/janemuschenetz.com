---
import Base from '../../layouts/Base.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

// Inline both SVGs at build time — strip XML/DOCTYPE and substitute missing fonts
function loadSvg(file: string) {
  return readFileSync(join(process.cwd(), file), 'utf-8')
    .replace(/<\?xml[^?]*\?>/g, '')
    .replace(/<!DOCTYPE[^>]*>/g, '')
    // MillerText-Roman / Miller Text is not loaded; replace with the site heading font
    .replace(/font-family:'MillerText-Roman', 'Miller Text'/g,
             "font-family:'Playfair Display', Georgia, serif")
    // Italic variant — preserve font-style if already set, just swap family
    .replace(/font-family:'MillerText-Italic', 'Miller Text'/g,
             "font-family:'Playfair Display', Georgia, serif")
    // Didot (used in meetoo_1.svg titles) → Playfair Display
    .replace(/font-family:'Didot-Bold', 'Didot'/g,
             "font-family:'Playfair Display', Georgia, serif")
    .trim();
}
const meSvg  = loadSvg('me.svg');
const tooSvg = loadSvg('too.svg');
---

<style>
  .live-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-lg);
  }
  .live-hero .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
  .live-hero .eyebrow a { color: inherit; text-decoration: none; }
  .live-hero .eyebrow a:hover { text-decoration: underline; }
  .live-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2px 8px;
    margin-left: 0.5rem;
    vertical-align: middle;
    color: var(--color-text-secondary);
  }

  /* ── Poem slides ─────────────────────────────────────────── */
  .slides {
    padding: var(--space-lg) 0 var(--space-xl);
  }
  .slide {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
  }
  .slide:first-child { border-top: none; }
  .slide-n {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
    font-family: var(--font-body);
  }
  .slide-text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.65;
    max-width: 640px;
  }

  /* ── SVG charts stacked vertically ──────────────────────── */
  .poem-section { padding: var(--space-md) 0 var(--space-lg); }

  .poem-epigraph {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(0.88rem, 1.4vw, 1rem);
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    max-width: 640px;
  }

  .mt-svg-stack {
    width: 100%;
  }

  /* Each chart panel takes full width */
  .mt-svg-panel {
    width: 100%;
    overflow: hidden;
  }
  .mt-svg-panel svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Data sources ────────────────────────────────────────── */
  .explore {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0 var(--space-xl);
  }
  .explore h2 { margin-bottom: 0.25rem; }
  .explore-intro {
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    max-width: 560px;
    margin-bottom: var(--space-lg);
  }
  .data-sources {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-sm);
  }
  .data-source-card {
    display: block;
    background: var(--color-bg-alt);
    border-radius: 4px;
    padding: var(--space-sm) var(--space-md);
    border-left: 3px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .data-source-card:hover { border-left-color: var(--color-text); }
  .data-source-card .source-org {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    margin-bottom: 0.3rem;
  }
  .data-source-card .source-title {
    font-size: 0.88rem;
    line-height: 1.4;
    color: var(--color-text);
  }
  .data-source-card .source-year {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  /* ── About ──────────────────────────────────────────────── */
  .poem-about {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0;
  }
</style>

<Base title="#ME TOO (Live) — Jane Muschenetz" description="An animated, interactive data poem on sexual violence prevalence, underreporting, and the shared economic burden.">

  <!-- Hero -->
  <section class="live-hero">
    <div class="container">
      <p class="eyebrow"><a href="/visual-data-poetry">&larr; Visual &amp; Data Poetry</a></p>
      <h1 class="page-hero__title">#ME TOO, a Point of Consensus <span class="live-badge">Interactive</span></h1>
      <p class="page-hero__subtitle" style="max-width:none;font-style:italic;">from <em>POWER POINT</em> (Sheila-Na-Gig Editions, 2024)</p>
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        <a href="/poems/metoo" class="link-underline">View original static version &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Poem Slides -->
  <section class="slides">
    <div class="container">
      <div class="slide">
        <p class="slide-n">1</p>
        <p class="slide-text">1 in every 4 American women<br>has experienced rape.</p>
      </div>
      <div class="slide">
        <p class="slide-n">2</p>
        <p class="slide-text">Of those who are assaulted,<br>fewer than 1 in 3 will ever report it.</p>
      </div>
      <div class="slide">
        <p class="slide-n">3</p>
        <p class="slide-text">All of us are paying for it.<br>The lifetime economic burden: over $6 trillion.</p>
      </div>
      <div class="slide">
        <p class="slide-n">4</p>
        <p class="slide-text">We know how to reduce it.<br>Evidence-based prevention programs work —<br>cutting incidents by up to 40%.</p>
      </div>
    </div>
  </section>

  <!-- Animated SVG charts stacked vertically -->
  <section class="poem-section">
    <div class="container">
      <p class="poem-epigraph">
        <em>The five charts correspond to the five letters of #METOO: Many are affected; Everyone knows their assailant; Timing skews young; Only a fraction report; there is Opportunity to change this.</em>
      </p>

      <div class="mt-svg-stack">
        <!-- M + E charts — bars animated by JS -->
        <div class="mt-svg-panel" id="panel-me">
          <Fragment set:html={meSvg} />
        </div>
        <!-- T + O + O charts -->
        <div class="mt-svg-panel" id="panel-too">
          <Fragment set:html={tooSvg} />
        </div>
      </div>
    </div>
  </section>

  <!-- Data Sources -->
  <section class="explore">
    <div class="container">
      <h2>Data Sources</h2>
      <p class="explore-intro">The five data sets behind the five charts of #METOO.</p>
      <div class="data-sources">
        <a class="data-source-card" href="https://www.cdc.gov/violenceprevention/sexualviolence/fastfact.html" target="_blank" rel="noopener">
          <p class="source-org">CDC</p>
          <p class="source-title">&ldquo;Preventing Sexual Violence&rdquo; &mdash; Fast Facts</p>
          <p class="source-year">2023</p>
        </a>
        <a class="data-source-card" href="https://bjs.ojp.gov/document/cv22.pdf" target="_blank" rel="noopener">
          <p class="source-org">US Dept. of Justice &mdash; Bureau of Justice Statistics</p>
          <p class="source-title">Criminal Victimization Report</p>
          <p class="source-year">2022</p>
        </a>
        <a class="data-source-card" href="https://www.rainn.org/statistics/scope-problem" target="_blank" rel="noopener">
          <p class="source-org">RAINN.org</p>
          <p class="source-title">&ldquo;Scope of the Problem&rdquo; &mdash; Statistics</p>
          <p class="source-year">2020</p>
        </a>
        <a class="data-source-card" href="https://www.ajpmonline.org/article/S0749-3797(16)30615-8/fulltext" target="_blank" rel="noopener">
          <p class="source-org">American Journal of Preventive Medicine</p>
          <p class="source-title">&ldquo;Lifetime Economic Burden of Rape Among US Adults&rdquo; &mdash; C. Peterson et al.</p>
          <p class="source-year">2017</p>
        </a>
        <a class="data-source-card" href="https://www.cdc.gov/violenceprevention/pdf/SV-Prevention-Resource_508.pdf" target="_blank" rel="noopener">
          <p class="source-org">CDC</p>
          <p class="source-title">&ldquo;Sexual Violence Prevention Resource for Action Report&rdquo;</p>
          <p class="source-year">2016</p>
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="poem-about">
    <div class="container--narrow">
      <h3>About This Poem</h3>
      <p>A two-page data visualization examining sexual violence in America. The five charts correspond to the five letters of #METOO: Many are affected; Everyone knows their assailant; Timing skews young; Only a fraction report; and there is Opportunity to change this through evidence-based prevention.</p>
    </div>
  </section>

  <script is:inline>
  (function () {
    // Animate all .mt-bar rects: each grows upward from its bottom edge on scroll.
    var bars = document.querySelectorAll('.mt-bar');
    if (!bars.length) return;

    var targets = [];
    bars.forEach(function (rect) {
      var targetH = parseFloat(rect.getAttribute('height'));
      var targetY = parseFloat(rect.getAttribute('y'));
      var bottom  = targetY + targetH;
      targets.push({ el: rect, targetH: targetH, bottom: bottom });
      rect.setAttribute('height', 0);
      rect.setAttribute('y', bottom);
    });

    function animateBars() {
      var start    = null;
      var duration = 1600;
      function step(ts) {
        if (!start) start = ts;
        var p = Math.min((ts - start) / duration, 1);
        var e = 1 - Math.pow(1 - p, 3); // ease-out cubic
        targets.forEach(function (item) {
          var h = item.targetH * e;
          item.el.setAttribute('height', h);
          item.el.setAttribute('y', item.bottom - h);
        });
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    var svg = document.querySelector('#panel-me svg');
    if (!svg) return;

    var observer = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        animateBars();
      }
    }, { threshold: 0.2 });
    observer.observe(svg);
  })();
  </script>

</Base>
