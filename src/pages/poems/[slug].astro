---
import { getCollection } from 'astro:content';
import Poem from '../../layouts/Poem.astro';
import ExploreData from '../../components/ExploreData.astro';

export async function getStaticPaths() {
  const poems = await getCollection('poems');
  return poems.map((poem) => ({
    params: { slug: poem.data.slug },
    props: { poem },
  }));
}

const { poem } = Astro.props;
const { title, description, subtitle, backHref, backText, type, image, imageAlt, image2, image2Alt, illustration, illustrationAlt, epigraphText, epigraphAttribution, poemText, srOnly, about, footnotes, resources } = poem.data;
---
<Poem title={title} description={description} subtitle={subtitle} backHref={backHref} backText={backText}>
  <!-- ====== Poem ====== -->
  <section>
    <div class="container">
      {type === 'image' && (
        <div class="poem-page-single">
          <img src={image} alt={imageAlt}>
        </div>
      )}

      {type === 'image-pair' && (
        <>
          <div class="poem-page-single">
            <img src={image} alt={imageAlt}>
          </div>
          <div class="poem-page-single" style="margin-top: 0;">
            <img src={image2} alt={image2Alt}>
          </div>
        </>
      )}

      {type === 'text' && (
        <div class="poem-text-layout">
          <div>
            {epigraphText && (
              <div class="poem-epigraph">
                &ldquo;{epigraphText}&rdquo;
                {epigraphAttribution && (
                  <span style="display:block; margin-top:0.5rem;">&mdash; {epigraphAttribution}</span>
                )}
              </div>
            )}
            {poemText && (
              <div class="poem-text" aria-label={`Poem: ${title}`} set:html={poemText.replace(/\n\n/g, '<br><br>').replace(/\n/g, '<br>')} />
            )}
          </div>
          {illustration && (
            <div class="poem-illustration">
              <img src={illustration} alt={illustrationAlt}>
            </div>
          )}
        </div>
      )}

      {srOnly && (
        <div class="sr-only">
          <p>{srOnly}</p>
        </div>
      )}
    </div>
  </section>

  <!-- ====== Commentary ====== -->
  <section class="poem-commentary">
    <div class="container">
      <h3>About This Poem</h3>
      {about.split('\n\n').map(p => <p set:html={p}></p>)}
      {footnotes.length > 0 && (
        <>
          <h4 class="mt-md">Data Sources</h4>
          <div class="poem-footnotes">
            <ol>
              {footnotes.map((note) => (
                <li set:html={note}></li>
              ))}
            </ol>
          </div>
        </>
      )}
    </div>
  </section>

  <!-- ====== Data Explorer ====== -->
  <ExploreData slug={poem.data.slug} />

  <!-- ====== Additional Resources ====== -->
  {resources && resources.length > 0 && (
    <section style="border-top: 1px solid var(--color-border); padding: var(--space-lg) 0;">
      <div class="container">
        <h3>Additional Resources</h3>
        <div class="poem-footnotes" style="border-top: none; padding-top: 0;">
          <ul>
            {resources.map((r) => (
              <li set:html={r}></li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}
</Poem>
