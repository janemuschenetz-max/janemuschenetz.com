---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  backHref?: string;
  backText?: string;
  staticHref?: string;
  awardText?: string;
  amazonLink?: string;
  publisherLink?: string;
  publisherName?: string;
}

const {
  title,
  description,
  subtitle = 'from <a href="https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/" target="_blank" rel="noopener noreferrer"><em>POWER POINT</em></a>, <span class="gleam-prize">winner of the 2025 National Press Women Communications Prize</span>',
  backHref = '/visual-data-poetry',
  backText = 'Visual &amp; Data Poetry',
  staticHref,
  awardText = '',
  amazonLink = 'https://www.amazon.com/Power-Point-Jane-Muschenetz/dp/1962405028/ref=sr_1_1?crid=GCKRJXP4AAPK&dib=eyJ2IjoiMSJ9.D5VuMTeV0OLUxn7L0cIHYrSnbrahVWtvaNEgwMsp5Go.8hBn07mxqiHgYFXJhV1L51QiirTsXjRmdG91xX8ZoT8&dib_tag=se&keywords=jane+muschenetz&qid=1773765718&sprefix=muschene%2Caps%2C262&sr=8-1',
  publisherLink = 'https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/',
  publisherName = 'Sheila-Na-Gig',
} = Astro.props;
---
<Base title={`${title} — Jane Muschenetz`} description={description}>
  <section class="page-hero">
    <div class="container">
      <p class="poem-eyebrow"><a href={backHref}>← <span set:html={backText} /></a></p>
      <h1 class="page-hero__title">{title}</h1>
      <p class="page-hero__subtitle" set:html={subtitle} />
      {awardText && (
        <p class="page-hero__award"><em>{awardText}</em></p>
      )}
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        {staticHref && (
          <><a href={staticHref} class="link-underline">View original static version →</a>&nbsp;·&nbsp;</>
        )}
        <span style="font-weight:500;color:var(--color-text);">Buy→</span> <a href={amazonLink} target="_blank" rel="noopener noreferrer">Amazon</a> · <a href={publisherLink} target="_blank" rel="noopener noreferrer">{publisherName}</a>
      </p>
    </div>
  </section>

  <slot />
</Base>

<style>
  .poem-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }
  .poem-eyebrow a {
    color: inherit;
    text-decoration: none;
  }
  .poem-eyebrow a:hover {
    text-decoration: underline;
  }
  :global(.page-hero) {
    padding-bottom: 0.8rem;
  }
  :global(.page-hero__subtitle) {
    max-width: none;
    white-space: nowrap;
  }
  :global(.page-hero__award) {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }
  @keyframes poem-prize-gleam {
    from { background-position: right center; }
    to   { background-position: left center; }
  }
  :global(.gleam-prize) {
    background: linear-gradient(
      90deg,
      var(--color-text) 0%,
      var(--color-text) 30%,
      rgba(180, 148, 80, 0.85) 43%,
      rgba(225, 195, 120, 1)   50%,
      rgba(180, 148, 80, 0.85) 57%,
      var(--color-text) 70%,
      var(--color-text) 100%
    );
    background-size: 300% 100%;
    background-position: right center;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: poem-prize-gleam 1.8s ease-in-out 0.8s 1 both;
  }
</style>
