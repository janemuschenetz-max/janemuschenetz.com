---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  backHref?: string;
  backText?: string;
  staticHref?: string;
  awardText?: string;
  amazonLink?: string;
  publisherLink?: string;
  publisherName?: string;
}

const {
  title,
  description,
  subtitle = 'from <a href="https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/" target="_blank" rel="noopener noreferrer"><em>POWER POINT</em> (Sheila-Na-Gig Editions, 2024)</a>',
  backHref = '/visual-data-poetry',
  backText = 'Visual &amp; Data Poetry',
  staticHref,
  awardText = 'Winner, 2025 National Press Women Communications Prize',
  amazonLink = 'https://www.amazon.com/Power-Point-Jane-Muschenetz/dp/1962405028/ref=sr_1_1?crid=GCKRJXP4AAPK&dib=eyJ2IjoiMSJ9.D5VuMTeV0OLUxn7L0cIHYrSnbrahVWtvaNEgwMsp5Go.8hBn07mxqiHgYFXJhV1L51QiirTsXjRmdG91xX8ZoT8&dib_tag=se&keywords=jane+muschenetz&qid=1773765718&sprefix=muschene%2Caps%2C262&sr=8-1',
  publisherLink = 'https://sheilanagigblog.com/shop-sheila-na-gig-editions/jane-muschenetz-powerpoint/',
  publisherName = 'Sheila-Na-Gig',
} = Astro.props;
---
<Base title={`${title} — Jane Muschenetz`} description={description}>
  <section class="page-hero">
    <div class="container">
      <h1 class="page-hero__title">{title}</h1>
      <p class="page-hero__subtitle" set:html={subtitle} />
      {awardText && (
        <p class="page-hero__award"><em>{awardText}</em></p>
      )}
      <p style="margin-top:var(--space-sm);font-size:0.85rem;color:var(--color-text-secondary);">
        {staticHref && (
          <><a href={staticHref} class="link-underline">View original static version →</a>&nbsp;·&nbsp;</>
        )}
        <span style="font-weight:500;color:var(--color-text);">Buy→</span> <a href={amazonLink} target="_blank" rel="noopener noreferrer">Amazon</a> · <a href={publisherLink} target="_blank" rel="noopener noreferrer">{publisherName}</a>
      </p>
    </div>
  </section>

  <slot />
</Base>

<style>
  :global(.page-hero) {
    padding-bottom: 0.8rem;
  }
  :global(.page-hero__subtitle) {
    max-width: none;
    white-space: nowrap;
  }
  :global(.page-hero__award) {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }
</style>
