---
import Header from '../components/Header.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  showDesktopNav?: boolean;
  ogImage?: string;
}

const {
  title,
  description = 'Poetic practice at the intersection of economics, science, and belonging.',
  showDesktopNav = true,
  ogImage = '/images/power-point-cover.jpg',
} = Astro.props;

const SITE = 'https://www.janemuschenetz.com';
const canonicalURL = new URL(Astro.url.pathname, SITE).href;
const ogImageURL = new URL(ogImage, SITE).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalURL}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Jane Yevgenia Muschenetz">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageURL}>
  <meta property="og:image:alt" content="Cover of POWER POINT by Jane Muschenetz (Sheila-Na-Gig Editions, 2024)">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageURL}>

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Jane Yevgenia Muschenetz",
    "url": "https://www.janemuschenetz.com",
    "sameAs": [
      "https://www.palmfrondzoo.com",
      "https://www.instagram.com/palmfrondzoo/",
      "https://www.facebook.com/jane.muschenetz",
      "https://www.linkedin.com/in/jane-muschenetz-b025b2a"
    ],
    "jobTitle": "Poet, Data Storyteller, and Speaker",
    "description": "Poet, data storyteller, and speaker whose work sits at the intersection of economics, science, and belonging. Known for data visualization poetry and visual poems that render real-world statistics into lyric form. Author of POWER POINT (Sheila-Na-Gig Editions, 2024).",
    "author": {
      "@type": "Book",
      "name": "POWER POINT",
      "publisher": {
        "@type": "Organization",
        "name": "Sheila-Na-Gig Editions"
      },
      "datePublished": "2024",
      "image": "https://www.janemuschenetz.com/images/power-point-cover.jpg"
    }
  })} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://use.typekit.net/jcy7qdd.css">
</head>
<body>
  <Header showDesktopNav={showDesktopNav} />
  <slot />
  <Newsletter />
  <Footer />
  <script src="/main.js" is:inline></script>
  <Analytics />
</body>
</html>
